 * WEEKLY TOOLS
 *************************/

const SIGN_UP_SHEET_URL = "https://docs.google.com/spreadsheets/d/1bk4ciJDNyjcV00yLPIzIvPyTKDLv9V4YYdZ8w0pDEpA/edit?gid=0#gid=0";

const DRAFT_TO = "spellingbeestagemanagers@gmail.com";

const REGULAR_PERF_SCHEDULE = {
  Monday: ["7p"],
  Tuesday: [],
  Wednesday: ["7p"],
  Thursday: ["7p"],
  Friday: ["7p"],
  Saturday: ["2p", "7:30p"],
  Sunday: ["2p", "7p"]
};

function createWeeklyEmailDraft() {
  const sourceSheet = SpreadsheetApp.getActiveSheet();

  if (!DRAFT_TO) {
    throw new Error("Add a recipient to DRAFT_TO at the top of the script first.");
  }

  const content = buildWeeklyEmailContent(sourceSheet);
  const signature = getStageOSEmailSignature_();

  const pdfBlob = getSheetPdfBlob(sourceSheet);

  GmailApp.createDraft(
    DRAFT_TO,
    content.subject,
    content.plainText + signature,
    {
      htmlBody: content.htmlBody + signatureToHtml_(signature),
      attachments: [pdfBlob]
    }
  );

  SpreadsheetApp.getUi().alert("Gmail draft created with PDF attached!");
}

function buildWeeklyEmailContent(sourceSheet) {
  const values = sourceSheet.getDataRange().getDisplayValues();
  const weekDates = getWeekDatesFromHeaders(values);

  const sections = {
    performances: {},
    castOuts: [],
    crewOuts: [],
    onstage: [],
    offsite: [],
    pt: [],
    trainings: [],
    misc: [],
    birthdays: [],
    holidays: []
  };

  let currentDay = "";

  for (let r = 0; r < values.length; r++) {
    const row = values[r];
    const colA = clean(row[0]);

    const dayMatch = colA.match(/^(Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday),\s+([A-Za-z]+)\s+(\d{1,2})$/i);

    if (dayMatch) {
      currentDay = `${dayMatch[1]} ${getMonthNumber(dayMatch[2])}.${String(dayMatch[3]).padStart(2, "0")}`;

      const headerText = clean(row.join(" "));
      addPerformance(headerText, currentDay, sections);
      addHolidayOrBirthdayFromHeader(row, currentDay, sections);

      continue;
    }

    if (!currentDay) continue;

    const rowItems = getRowItems(row);

    rowItems.forEach(item => {
      addPerformance(item, currentDay, sections);
      categorizeItem(item, currentDay, sections);
    });
  }

  const perfInfo = buildPerformanceSchedule(sections.performances, weekDates);
  const perfHeader = perfInfo.hasChange
    ? "CHANGE IN PERF. SCHEDULE THIS WEEK:"
    : "REG PERF. SCHEDULE THIS WEEK:";

  const emailParts = [];

  emailParts.push("Hello Spelling Bee Company,");
  emailParts.push("");

  if (weekDates.length >= 2) {
    const first = weekDates[0];
    const last = weekDates[weekDates.length - 1];
    emailParts.push(`Please find the Weekly Schedule for ${first.fullDate} - ${last.fullDate} attached and below.`);
    emailParts.push("");
  }

  emailParts.push("PLEASE NOTE:");
  emailParts.push("");

  addSection(emailParts, perfHeader, perfInfo.lines);
  addSection(emailParts, "CAST OUTS:", combineDateRanges(dedupeLines(sections.castOuts)));
  addSection(emailParts, "CREW OUTS:", combineDateRanges(dedupeLines(sections.crewOuts)));
  addSection(emailParts, "ONSTAGE REHEARSALS:", groupSameDayLines(dedupeLines(sections.onstage)));
  addSection(emailParts, "NEW SCHWARTZY OFFSITE REHEARSALS:", dedupeLines(sections.offsite));

  const ptLines = dedupeLines(sections.pt);
  if (SIGN_UP_SHEET_URL) ptLines.push("SIGN UP SHEET");
  addSection(emailParts, "PT:", ptLines);

  addSection(emailParts, "TRAININGS:", combineDateRanges(dedupeLines(sections.trainings)));
  addSection(emailParts, "MISC:", combineDateRanges(dedupeLines(sections.misc)));
  addSection(emailParts, "BIRTHDAYS:", dedupeLines(sections.birthdays));
  addSection(emailParts, "HOLIDAYS:", dedupeLines(sections.holidays));

  emailParts.push("Please reach out with any questions or concerns.");

  const plainText = emailParts.join("\n");

  return {
    plainText,
    htmlBody: buildHtmlEmail(plainText),
    subject: weekDates.length >= 2
      ? `SPELLING BEE - Weekly Schedule - ${weekDates[0].fullDate} - ${weekDates[weekDates.length - 1].fullDate}`
      : "SPELLING BEE - Weekly Schedule"
  };
}

function addHolidayOrBirthdayFromHeader(row, currentDay, sections) {
  const headerExtra = clean(row.slice(1, 5).join(" "));
  const lower = headerExtra.toLowerCase();

  if (!headerExtra) return;

  if (lower.includes("birthday")) {
    sections.birthdays.push(`- ${currentDay}: ${headerExtra}`);
  }

  const holiday = extractHoliday(headerExtra);
  if (holiday) {
    sections.holidays.push(`- ${currentDay}: ${holiday}`);
  }
}

function extractHoliday(text) {
  const lower = text.toLowerCase();

  const knownHolidays = [
    "New Year's Day",
    "New Years Day",
    "Martin Luther King Jr. Day",
    "Martin Luther King, Jr. Day",
    "MLK Day",
    "Washington's Birthday",
    "Washingtons Birthday",
    "Presidents Day",
    "President's Day",
    "Memorial Day",
    "Juneteenth",
    "Juneteenth National Independence Day",
    "Independence Day",
    "Fourth of July",
    "4th of July",
    "Labor Day",
    "Columbus Day",
    "Indigenous Peoples' Day",
    "Indigenous Peoples Day",
    "Veterans Day",
    "Veteran's Day",
    "Thanksgiving",
    "Thanksgiving Day",
    "Christmas",
    "Christmas Day",
    "Christmas Eve",
    "New Year's Eve",
    "New Years Eve",
    "Halloween",
    "Valentine's Day",
    "Valentines Day",
    "Mother's Day",
    "Mothers Day",
    "Father's Day",
    "Fathers Day",
    "Easter",
    "Good Friday",
    "Palm Sunday",
    "Ash Wednesday",
    "Passover",
    "Yom Kippur",
    "Rosh Hashanah",
    "Hanukkah",
    "Chanukah",
    "Diwali",
    "Eid",
    "Eid al-Fitr",
    "Eid al-Adha",
    "Flag Day"
  ];

  for (const holiday of knownHolidays) {
    if (lower.includes(holiday.toLowerCase())) {
      return holiday;
    }
  }

  const holidayMatch = text.match(/HOLIDAY:?\s*(.+)$/i);
  if (holidayMatch) return holidayMatch[1].trim();

  return "";
}

function buildHtmlEmail(plainText) {
  const headers = getHeaders();
  let currentSection = "";

  return plainText.split("\n").map(line => {
    if (line === "") {
      return `<div style="height:10px;"></div>`;
    }

    if (line === "SIGN UP SHEET") {
      return `<div><a href="${SIGN_UP_SHEET_URL}">SIGN UP SHEET</a></div>`;
    }

    if (headers.includes(line)) {
      currentSection = line;
      return `<div style="font-weight:bold; margin-top:14px;">${escapeHtml(line)}</div>`;
    }

    if (currentSection === "CAST OUTS:" && line.startsWith("- ")) {
      const castMatch = line.match(/^(-\s+[A-Za-z]+\s+\d+\.\d+(?:\s+-\s+[A-Za-z]+\s+\d+\.\d+)?:)\s*(.*)$/);

      if (castMatch) {
        return `<div><strong>${escapeHtml(castMatch[1])}</strong> <span style="color:#FF0000;">${escapeHtml(castMatch[2])}</span></div>`;
      }
    }

    if (line.startsWith("   • ")) {
      return `<div style="margin-left:24px;">• ${formatInlineHtml(line.replace(/^   •\s*/, ""))}</div>`;
    }

    return `<div>${formatInlineHtml(line)}</div>`;
  }).join("");
}

function formatInlineHtml(line) {
  let formatted = escapeHtml(line);

  formatted = formatted.replace(
    /^(-\s+[A-Za-z]+\s+\d+\.\d+(?:\s+-\s+[A-Za-z]+\s+\d+\.\d+)?:)/,
    "<strong>$1</strong>"
  );

  formatted = formatted.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
  formatted = formatted.replace(/\*\*CHANGE\*\*/g, "<strong>CHANGE</strong>");

  return formatted;
}

function getSheetPdfBlob(sheet) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const ssId = ss.getId();
  const sheetId = sheet.getSheetId();

  const url =
    `https://docs.google.com/spreadsheets/d/${ssId}/export?` +
    `format=pdf` +
    `&gid=${sheetId}` +
    `&size=letter` +
    `&portrait=true` +
    `&fitw=true` +
    `&sheetnames=false` +
    `&printtitle=false` +
    `&pagenumbers=false` +
    `&gridlines=false` +
    `&fzr=false`;

  const token = ScriptApp.getOAuthToken();

  const response = UrlFetchApp.fetch(url, {
    headers: {
      Authorization: `Bearer ${token}`
    }
  });

  return response.getBlob().setName(`SPELLING BEE - ${sheet.getName()}.pdf`);
}

function getWeekDatesFromHeaders(values) {
  const foundDates = [];

  values.forEach(row => {
    const colA = clean(row[0]);
    const match = colA.match(/^(Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday),\s+([A-Za-z]+)\s+(\d{1,2})$/i);

    if (match) {
      const dayName = match[1];
      const monthName = match[2];
      const dayNum = Number(match[3]);
      const monthNum = getMonthNumber(monthName);

      foundDates.push({
        dayName,
        monthName,
        dayNum,
        monthNum
      });
    }
  });

  if (foundDates.length === 0) return [];

  const dayOrder = {
    Monday: 0,
    Tuesday: 1,
    Wednesday: 2,
    Thursday: 3,
    Friday: 4,
    Saturday: 5,
    Sunday: 6
  };

  const monday = foundDates.find(d => d.dayName === "Monday") || foundDates[0];
  const year = new Date().getFullYear();
  const mondayDate = new Date(year, monday.monthNum - 1, monday.dayNum);

  return Object.keys(dayOrder).map(dayName => {
    const date = new Date(mondayDate);
    date.setDate(mondayDate.getDate() + dayOrder[dayName]);

    const monthName = getMonthName(date.getMonth() + 1);
    const monthNum = date.getMonth() + 1;
    const dayNum = date.getDate();

    return {
      dayName,
      monthName,
      dayNum,
      monthNum,
      label: `${dayName} ${monthNum}.${String(dayNum).padStart(2, "0")}`,
      fullDate: `${dayName}, ${monthName} ${String(dayNum).padStart(2, "0")}`
    };
  });
}

function addPerformance(text, currentDay, sections) {
  if (!/performance/i.test(text)) return;

  if (!sections.performances[currentDay]) {
    sections.performances[currentDay] = [];
  }

  const matches = [...text.matchAll(/PERFORMANCE\s*#?\d*\s*-?\s*(\d{1,2}):(\d{2})\s*(AM|PM)/gi)];

  matches.forEach(match => {
    const hour = Number(match[1]);
    const minute = match[2];
    const label = minute === "00" ? `${hour}p` : `${hour}:${minute}p`;

    if (!sections.performances[currentDay].includes(label)) {
      sections.performances[currentDay].push(label);
    }
  });
}

function buildPerformanceSchedule(performances, weekDates) {
  let hasChange = false;

  const lines = weekDates.map(day => {
    const actual = performances[day.label] || [];
    const regular = REGULAR_PERF_SCHEDULE[day.dayName] || [];

    const changed = actual.slice().sort().join("|") !== regular.slice().sort().join("|");
    if (changed) hasChange = true;

    if (actual.length === 0) {
      return `- ${day.label}: OFF${changed ? " **CHANGE**" : ""}`;
    }

    const display = actual.length === 1
      ? actual[0]
      : `${actual[0]} Mat & ${actual[1]} Eve`;

    return `- ${day.label}: ${display}${changed ? " **CHANGE**" : ""}`;
  });

  return { lines, hasChange };
}

function addSection(emailParts, header, lines) {
  if (!lines || lines.length === 0) return;
  emailParts.push(header);
  lines.forEach(line => emailParts.push(line));
  emailParts.push("");
}

function getRowItems(row) {
  const colA = String(row[0] || "").trim();
  const isNotesRow = /^NOTES:?$/i.test(colA);

  if (isNotesRow) {
    const items = [];

    row.forEach(cell => {
      String(cell || "")
        .replace(/^NOTES:\s*/i, "")
        .split(/\n/g)
        .map(part => clean(part))
        .filter(Boolean)
        .forEach(part => items.push(part));
    });

    return items;
  }

  const joined = clean(row.join(" "));
  return joined ? [joined] : [];
}

function categorizeItem(text, currentDay, sections) {
  const item = formatLine(text);
  if (!item) return;

  const lower = item.toLowerCase();
  if (lower === "notes:") return;

  // VERY IMPORTANT:
  // Put-Ins must be classified before Cast Outs/Crew Outs,
  // because they often contain "Jasmine R. OUT" / "Jahbril C. OUT"
  // as internal Put-In notes.
  if (isPutInBlock(item)) {
    sections.onstage.push(`- ${currentDay}: ${item}`);
  } else if (isCastOut(item)) {
    sections.castOuts.push(`- ${currentDay}: ${formatCastOut(item)}`);
  } else if (isCrewOut(item)) {
    sections.crewOuts.push(`- ${currentDay}: ${formatCrewOut(item)}`);
  } else if (lower.includes("offsite rehearsal")) {
    sections.offsite.push(`- ${currentDay}: ${item}`);
  } else if (lower.includes("rehearsal") && !lower.includes("watch show")) {
    sections.onstage.push(`- ${currentDay}: ${item}`);
  } else if (/^pt\b/i.test(item)) {
    sections.pt.push(`- ${currentDay}: ${item.replace(/^PT\s*/i, "")}`);
  } else if (lower.includes("training") || lower.includes("mixing")) {
    sections.trainings.push(`- ${currentDay}: ${item}`);
  } else if (lower.includes("birthday")) {
    sections.birthdays.push(`- ${currentDay}: ${item}`);
  } else if (lower.includes("holiday") || extractHoliday(item)) {
    const holiday = extractHoliday(item) || item;
    sections.holidays.push(`- ${currentDay}: ${holiday}`);
  } else if (
    lower.includes("press") ||
    lower.includes("production check-in") ||
    lower.includes("onboarding") ||
    lower.includes("measurements") ||
    lower.includes("watch show") ||
    lower.includes("personal work")
  ) {
    sections.misc.push(`- ${currentDay}: ${cleanMiscLine(item)}`);
  }
}

function isPutInBlock(text) {
  const lower = text.toLowerCase();
  return lower.includes("understudy put-in") || lower.includes("understudy put in") || lower.match(/put-?in\s*#\d+/);
}

function cleanMiscLine(text) {
  return String(text || "")
    .replace(/\s+Wardrobe Crew Call.*$/i, "")
    .trim();
}

function groupSameDayLines(lines) {
  const grouped = {};
  const order = [];

  lines.forEach(line => {
    const match = line.match(/^- ([A-Za-z]+ \d{1,2}\.\d{2}):\s*(.+)$/);

    if (!match) {
      order.push({ type: "raw", line });
      return;
    }

    const date = match[1];
    const text = match[2];

    if (!grouped[date]) {
      grouped[date] = [];
      order.push({ type: "date", date });
    }

    grouped[date].push(text);
  });

  const output = [];

  order.forEach(item => {
    if (item.type === "raw") {
      output.push(item.line);
      return;
    }

    const items = grouped[item.date];

    if (items.length === 1) {
      output.push(`- ${item.date}: ${items[0]}`);
    } else {
      output.push(`- ${item.date}:`);
      items.forEach(text => {
        output.push(`   • ${text}`);
      });
    }
  });

  return output;
}

function combineDateRanges(lines) {
  const dayOrder = {
    Monday: 1,
    Tuesday: 2,
    Wednesday: 3,
    Thursday: 4,
    Friday: 5,
    Saturday: 6,
    Sunday: 7
  };

  const grouped = {};

  lines.forEach(line => {
    const match = line.match(/^- ([A-Za-z]+) (\d{1,2})\.(\d{2})\s*: (.+)$/);
    if (!match) return;

    const item = {
      dayName: match[1],
      monthNum: match[2],
      dayNum: Number(match[3]),
      dayOrder: dayOrder[match[1]],
      text: cleanForRange(match[4])
    };

    if (!grouped[item.text]) grouped[item.text] = {};
    grouped[item.text][item.dayOrder] = item;
  });

  const combined = [];

  Object.keys(grouped).forEach(text => {
    const group = Object.values(grouped[text]).sort((a, b) => a.dayOrder - b.dayOrder);

    if (group.length === 1) {
      const only = group[0];
      combined.push(`- ${only.dayName} ${only.monthNum}.${String(only.dayNum).padStart(2, "0")}: ${text}`);
      return;
    }

    const first = group[0];
    const last = group[group.length - 1];

    combined.push(
      `- ${first.dayName} ${first.monthNum}.${String(first.dayNum).padStart(2, "0")} - ${last.dayName} ${last.monthNum}.${String(last.dayNum).padStart(2, "0")}: ${text}`
    );
  });

  return combined;
}

function getHeaders() {
  return [
    "PLEASE NOTE:",
    "REG PERF. SCHEDULE THIS WEEK:",
    "CHANGE IN PERF. SCHEDULE THIS WEEK:",
    "CAST OUTS:",
    "CREW OUTS:",
    "ONSTAGE REHEARSALS:",
    "NEW SCHWARTZY OFFSITE REHEARSALS:",
    "PT:",
    "TRAININGS:",
    "MISC:",
    "BIRTHDAYS:",
    "HOLIDAYS:"
  ];
}

function dedupeLines(lines) {
  return [...new Set(lines)];
}

function clean(text) {
  return String(text || "")
    .replace(/^NOTES:\s*/i, "")
    .replace(/^-+\s*/, "")
    .replace(/\s+/g, " ")
    .trim();
}

function cleanForRange(text) {
  return String(text || "")
    .replace(/\s+\((Mat|Eve|Mat & Eve|Mat \+ Eve|Mat & Tentatively Eve)\)$/i, "")
    .replace(/\s+in the evenings\.?$/i, "")
    .trim();
}

function formatLine(text) {
  return clean(text);
}

function isCastOut(text) {
  const lower = text.toLowerCase();

  if (!lower.includes("out")) return false;

  return (
    lower.includes("mitch") ||
    lower.includes("rona") ||
    lower.includes("barfée") ||
    lower.includes("barfee") ||
    lower.includes("olive") ||
    lower.includes("chip") ||
    lower.includes("marcy") ||
    lower.includes("logainne") ||
    lower.includes("panch") ||
    lower.includes("comfort counselor") ||
    lower.includes("schwartzy") ||
    /^[A-Za-z]+(?:\s+[A-Z]\.)?\s+OUT$/i.test(text)
  );
}

function isCrewOut(text) {
  const lower = text.toLowerCase();

  const crewPatterns = [
    /\bin as asm\b/,
    /\bpsm\b/,
    /\basm\b/,
    /\bwardrobe\b/,
    /\bspot\b/,
    /\blx\b/,
    /\bsound\b/,
    /\ba1\b/,
    /\ba2\b/,
    /\bdeck\b/,
    /\bprops\b/,
    /\bboard\b/,
    /\bcrew\b/
  ];

  return lower.includes("out") && crewPatterns.some(pattern => pattern.test(lower));
}

function formatCastOut(text) {
  return formatLine(text)
    .replace(/Mitch\s*=\s*([^,]+)/i, "$1 IN as Mitch")
    .replace(/Rona\s*=\s*([^,]+)/i, "$1 IN as Rona")
    .replace(/Barfée\s*=\s*([^,]+)/i, "$1 IN as Barfée")
    .replace(/Olive\s*=\s*([^,]+)/i, "$1 IN as Olive");
}

function formatCrewOut(text) {
  return cleanForRange(formatLine(text));
}

function getMonthNumber(monthName) {
  const months = {
    January: 1,
    February: 2,
    March: 3,
    April: 4,
    May: 5,
    June: 6,
    July: 7,
    August: 8,
    September: 9,
    October: 10,
    November: 11,
    December: 12
  };

  return months[monthName] || 6;
}

function getMonthName(monthNum) {
  const months = [
    "",
    "January",
    "February",
    "March",
    "April",
    "May",
    "June",
    "July",
    "August",
    "September",
    "October",
    "November",
    "December"
  ];

  return months[monthNum];
}

function escapeHtml(text) {
  return String(text || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
}

/*************************************************
 * 25 WEEKLYOS - SOURCES
 * Version: 0.3.0
 * Status: ACTIVE DEVELOPMENT
 *
 * Builds the initial WeekModel from:
 *
 * - Expanded Calendar
 * - Production Cal w/Conflicts
 * - PD/Vacation Tracker
 * - Crew Outs
 * - Contact Sheet
 *
 * Source philosophy:
 *
 * Expanded Calendar
 *   = schedule backbone
 *
 * Production Cal w/Conflicts
 *   = cast outs + company activity
 *
 * PD/Vacation Tracker
 *   = cast-out enrichment / approval validation
 *
 * Crew Outs
 *   = crew-out source + coverage
 *
 * Contact Sheet
 *   = people / role / department reference
 *************************************************/


/*************************************************
 * BUILD NEW DRAFT
 *************************************************/

function weeklyOSBuildDraft(weekStart) {
  const draft =
    weeklyOSCreateWeekDraft_(
      weekStart ||
      weeklyOSNextMonday_()
    );

  weeklyOSLog_(
    "Building weekly draft.",
    {
      weekStart:
        draft.weekStart,

      weekEnd:
        draft.weekEnd
    }
  );

  const peopleIndex =
    weeklyOSReadContactSheet_(
      draft
    );

  weeklyOSReadExpandedCalendar_(
    draft
  );

  /*
  * Read dedicated rehearsal calendars such as:
  * New Olive + Rona
  */
  // weeklyOSReadNewActorCalendars_(
  //   draft
  // );

  weeklyOSReadProductionCalendar_(
    draft,
    peopleIndex
  );

  weeklyOSReadPdVacationTracker_(
    draft,
    peopleIndex
  );

  weeklyOSReadCrewOuts_(
    draft,
    peopleIndex
  );

  weeklyOSEnrichOutsFromPeopleIndex_(
    draft,
    peopleIndex
  );

  weeklyOSDeduplicateDraftSources_(
    draft
  );

  draft.metadata.lastSourceRefreshAt =
    weeklyOSNowIso_();

  weeklyOSRecalculateDraft_(
    draft
  );

  weeklyOSSaveDraft(
    draft
  );

  weeklyOSLog_(
    "Weekly draft built.",
    weeklyOSBuildDraftSummary_(
      draft
    )
  );

  return draft;
}


/*************************************************
 * REFRESH EXISTING DRAFT
 *
 * Rebuilds source data but preserves:
 *
 * - Manual rehearsals
 * - Manual meetings
 * - Manual work calls
 * - Manual put-ins
 * - Manual notes
 * - Coverage choices
 * - Review status
 *************************************************/

function weeklyOSRefreshDraft() {
  const currentDraft =
    weeklyOSGetDraft();

  if (!currentDraft) {
    return weeklyOSBuildDraft(
      weeklyOSNextMonday_()
    );
  }

  const refreshedDraft =
    weeklyOSCreateWeekDraft_(
      currentDraft.weekStart
    );

  const peopleIndex =
    weeklyOSReadContactSheet_(
      refreshedDraft
    );

  weeklyOSReadExpandedCalendar_(
    refreshedDraft
  );

  /*
  * Refresh dedicated new-actor rehearsal calendars.
  */
  // weeklyOSReadNewActorCalendars_(
  //   refreshedDraft
  // );

  weeklyOSReadProductionCalendar_(
    refreshedDraft,
    peopleIndex
  );

  weeklyOSReadPdVacationTracker_(
    refreshedDraft,
    peopleIndex
  );

  weeklyOSReadCrewOuts_(
    refreshedDraft,
    peopleIndex
  );

  weeklyOSEnrichOutsFromPeopleIndex_(
    refreshedDraft,
    peopleIndex
  );

  weeklyOSMergeManualDraftEdits_(
    refreshedDraft,
    currentDraft
  );

  weeklyOSDeduplicateDraftSources_(
    refreshedDraft
  );

  refreshedDraft.id =
    currentDraft.id;

  refreshedDraft.revision =
    Number(
      currentDraft.revision || 1
    ) + 1;

  refreshedDraft.createdAt =
    currentDraft.createdAt;

  refreshedDraft.metadata =
    Object.assign(
      {},
      currentDraft.metadata || {},
      {
        lastSourceRefreshAt:
          weeklyOSNowIso_()
      }
    );

  weeklyOSRecalculateDraft_(
    refreshedDraft
  );

  weeklyOSSaveDraft(
    refreshedDraft
  );

  return refreshedDraft;
}


/*************************************************
 * EXPANDED CALENDAR
 *
 * Confirmed layout:
 *
 * A = DATE
 * B = WHAT
 * C = TIME
 * D = PLANNED GUEST SPELLERS
 * E = SM CONFIRMED
 * F = CONDUCTOR
 * G = PT
 *************************************************/

function weeklyOSReadExpandedCalendar_(
  draft
) {
  const config =
    weeklyOSGetConfig_();

  const status =
    draft.sourceStatus
      .expandedCalendar;

  status.checkedAt =
    weeklyOSNowIso_();

  const sheet =
    weeklyOSGetSheetSafe_(
      config.sheets
        .expandedCalendar
    );

  if (!sheet) {
    status.status =
      "NOT_FOUND";

    status.details =
      'Sheet "' +
      config.sheets
        .expandedCalendar +
      '" was not found.';

    return;
  }

  status.found = true;
  status.status = "FOUND";

  const lastRow =
    sheet.getLastRow();

  if (lastRow < 2) {
    status.details =
      "Expanded Calendar contains no schedule rows.";

    return;
  }

  const rawValues =
    sheet
      .getRange(
        2,
        1,
        lastRow - 1,
        7
      )
      .getValues();

  const displayValues =
    sheet
      .getRange(
        2,
        1,
        lastRow - 1,
        7
      )
      .getDisplayValues();

  let currentDate = null;
  let currentDateKey = "";
  let currentConductor = "";

  let performanceCount = 0;
  let rehearsalCount = 0;
  let workCallCount = 0;
  let putInCount = 0;
  let dayOffCount = 0;
  let ptCount = 0;

  for (
    let index = 0;
    index < rawValues.length;
    index++
  ) {
    const rowNumber =
      index + 2;

    const rawRow =
      rawValues[index];

    const displayRow =
      displayValues[index];

    const dateValue =
      rawRow[0] ||
      displayRow[0];

    const parsedDate =
  weeklyOSAsDate_(
    dateValue
  );

if (parsedDate) {
  const nextDate =
    weeklyOSStartOfDay_(
      parsedDate
    );

  const nextDateKey =
    weeklyOSDateKey_(
      nextDate
    );

  /*
   * Reset carried values whenever a new calendar
   * date begins.
   */
  if (
    nextDateKey &&
    nextDateKey !== currentDateKey
  ) {
    currentConductor = "";
  }

  currentDate =
    nextDate;

  currentDateKey =
    nextDateKey;
}    

    if (!currentDate) {
      continue;
    }

    if (
      !weeklyOSDateIsWithinRange_(
        currentDate,
        draft.weekStart,
        draft.weekEnd
      )
    ) {
      continue;
    }

    const day =
      weeklyOSGetDay_(
        draft,
        currentDate
      );

    if (!day) {
      continue;
    }

    const what =
      weeklyOSNormalizeText_(
        displayRow[1]
      );

    const time =
      weeklyOSNormalizeText_(
        displayRow[2]
      );

    const guestSpeller =
      weeklyOSNormalizeText_(
        displayRow[3]
      );

    const smConfirmed =
      Boolean(
        rawRow[4]
      );

    const rowConductor =
  weeklyOSNormalizeText_(
    displayRow[5]
  );

/*
 * Expanded Calendar may use one conductor cell for
 * an entire date or a merged two-performance block.
 *
 * A nonblank row value becomes the current conductor.
 * Blank performance rows inherit that value.
 *
 * If the Evening performance has a different named
 * conductor, its row value replaces the Matinee value.
 */
if (rowConductor) {
  currentConductor =
    rowConductor;
}

const conductor =
  rowConductor ||
  currentConductor ||
  "";

    const pt =
      weeklyOSNormalizeText_(
        displayRow[6]
      );

    if (
      what ||
      time ||
      guestSpeller ||
      conductor ||
      pt
    ) {
      day.sources
        .expandedCalendar = true;
    }

    if (pt) {
      const ptTimes =
        weeklyOSParseTimeRange_(
          pt
        );

      day.pt.push(
        weeklyOSCreatePt_({
          startTime:
            ptTimes.startTime,

          endTime:
            ptTimes.endTime,

          location:
            ptTimes.location ||
            "Balcony",

          notes:
            pt,

          source:
            "Expanded Calendar",

          sourceRow:
            rowNumber
        })
      );

      ptCount++;
    }

    if (!what) {
      continue;
    }

    const upperWhat =
      weeklyOSUpper_(
        what
      );

    if (
      upperWhat.indexOf(
        "PERFORMANCE"
      ) >= 0
    ) {
      const performanceNumber =
        weeklyOSExtractPerformanceNumber_(
          what
        );

      const showType =
        weeklyOSDetermineShowType_(
          time,
          what
        );

      day.performances.push(
        weeklyOSCreatePerformance_({
          performanceNumber:
            performanceNumber,

          label:
            what,

          time:
            time,

          showType:
            showType,

          conductor:
            conductor,

          guestSpeller:
            guestSpeller,

          smConfirmed:
            smConfirmed,

          source:
            "Expanded Calendar",

          sourceRow:
            rowNumber
        })
      );

      performanceCount++;
      continue;
    }

    if (
      upperWhat.indexOf(
        "AEA DAY OFF"
      ) >= 0
    ) {
      day.dayOff =
        weeklyOSCreateDayOff_({
          type:
            "AEA_DAY_OFF",

          title:
            "AEA DAY OFF",

          source:
            "Expanded Calendar",

          sourceRow:
            rowNumber
        });

      dayOffCount++;
      continue;
    }

    if (
      upperWhat.indexOf(
        "PUT-IN"
      ) >= 0 ||
      upperWhat.indexOf(
        "PUT IN"
      ) >= 0
    ) {
      const putInTimes =
        weeklyOSParseTimeRange_(
          time
        );

      day.putIns.push(
        weeklyOSCreatePutIn_({
          title:
            what,

          startTime:
            putInTimes.startTime,

          endTime:
            putInTimes.endTime,

          location:
            "",

          requiresReview:
            true,

          source:
            "Expanded Calendar",

          sourceRow:
            rowNumber
        })
      );

      putInCount++;
      continue;
    }

    if (
      upperWhat.indexOf(
        "WORK CALL"
      ) >= 0
    ) {
      const workCallTimes =
        weeklyOSParseTimeRange_(
          time
        );

      day.workCalls.push(
        weeklyOSCreateWorkCall_({
          title:
            what,

          startTime:
            workCallTimes.startTime,

          endTime:
            workCallTimes.endTime,

          source:
            "Expanded Calendar",

          sourceRow:
            rowNumber
        })
      );

      workCallCount++;
      continue;
    }

    if (
      upperWhat.indexOf(
        "REH"
      ) >= 0 ||
      upperWhat.indexOf(
        "REHEARSAL"
      ) >= 0
    ) {
      const rehearsalTimes =
        weeklyOSParseTimeRange_(
          time
        );

      const rehearsalType =
        weeklyOSDetermineRehearsalType_(
          what
        );

      const isUnderstudy =
        rehearsalType ===
        "UNDERSTUDY";

      const isNewHire =
        rehearsalType ===
        "NEW_HIRE";

      const defaults =
        isUnderstudy
          ? config
              .rehearsalDefaults
              .understudy
          : isNewHire
            ? config
                .rehearsalDefaults
                .newHire
            : {};

      day.rehearsals.push(
        weeklyOSCreateRehearsal_({
          type:
            rehearsalType,

          title:
            what,

          startTime:
            rehearsalTimes
              .startTime,

          endTime:
            rehearsalTimes
              .endTime,

          location:
            defaults.location ||
            "",

          called:
            defaults.called ||
            [],

          goldDividerBeforePerformance:
            Boolean(
              defaults
                .goldDividerBeforePerformance
            ),

          notes:
            upperWhat.indexOf(
              "TBD"
            ) >= 0
              ? "Potential rehearsal detected. Confirm details or mark canceled."
              : "",

          requiresReview:
            (
              upperWhat.indexOf(
                "TBD"
              ) >= 0 ||
              isNewHire
            ),

          source:
            "Expanded Calendar",

          sourceRow:
            rowNumber
        })
      );

      rehearsalCount++;
      continue;
    }

    weeklyOSRouteExpandedCalendarOtherItem_(
      day,
      {
        what:
          what,

        time:
          time,

        guestSpeller:
          guestSpeller,

        conductor:
          conductor,

        sourceRow:
          rowNumber
      }
    );
  }

  status.details = [
    performanceCount +
      " performance(s)",

    rehearsalCount +
      " rehearsal(s)",

    putInCount +
      " put-in(s)",

    workCallCount +
      " work call(s)",

    dayOffCount +
      " day-off item(s)",

    ptCount +
      " PT item(s)"
  ].join(" • ");
}


/*************************************************
 * ROUTE OTHER EXPANDED CALENDAR ITEM
 *************************************************/

function weeklyOSRouteExpandedCalendarOtherItem_(
  day,
  item
) {
  const upper =
    weeklyOSUpper_(
      item.what
    );

  if (
    upper.indexOf(
      "MEETING"
    ) >= 0
  ) {
    const times =
      weeklyOSParseTimeRange_(
        item.time
      );

    day.meetings.push(
      weeklyOSCreateMeeting_({
        title:
          item.what,

        startTime:
          times.startTime,

        endTime:
          times.endTime,

        source:
          "Expanded Calendar",

        sourceRow:
          item.sourceRow
      })
    );

    return;
  }

  day.notes.push(
    weeklyOSCreateNote_({
      text:
        [
          item.what,
          item.time
        ]
          .filter(Boolean)
          .join(" — "),

      category:
        "SCHEDULE",

      source:
        "Expanded Calendar",

      sourceRow:
        item.sourceRow
    })
  );
}


/*************************************************
 * PRODUCTION CALENDAR
 *
 * The Production Calendar is a visual month grid.
 *
 * WeeklyOS scans:
 *
 * - Date-number rows
 * - Content rows beneath each date
 * - Red cast-out text
 * - Blue company activity text
 * - Holidays and special events
 *************************************************/

function weeklyOSReadProductionCalendar_(
  draft,
  peopleIndex
) {
  const config =
    weeklyOSGetConfig_();

  const status =
    draft.sourceStatus
      .productionCalendar;

  status.checkedAt =
    weeklyOSNowIso_();

  const sheet =
    weeklyOSGetSheetSafe_(
      config.sheets
        .productionCalendar
    );

  if (!sheet) {
    status.status =
      "NOT_FOUND";

    status.details =
      'Sheet "' +
      config.sheets
        .productionCalendar +
      '" was not found.';

    return;
  }

  status.found = true;
  status.status = "FOUND";

  const range =
    sheet.getDataRange();

  const displayValues =
    range.getDisplayValues();

  const fontColors =
    range.getFontColors();

  const monthBlocks =
    weeklyOSFindProductionCalendarMonthBlocks_(
      displayValues
    );

  let castOutCount = 0;
  let companyEventCount = 0;
  let holidayCount = 0;
  let noteCount = 0;

  monthBlocks.forEach(
    function (monthBlock) {
      const parsed =
        weeklyOSParseProductionCalendarMonth_(
          draft,
          displayValues,
          fontColors,
          monthBlock,
          peopleIndex
        );

      castOutCount +=
        parsed.castOutCount;

      companyEventCount +=
        parsed.companyEventCount;

      holidayCount +=
        parsed.holidayCount;

      noteCount +=
        parsed.noteCount;
    }
  );

  status.details = [
    castOutCount +
      " cast out(s)",

    companyEventCount +
      " company event(s)",

    holidayCount +
      " holiday item(s)",

    noteCount +
      " calendar note(s)"
  ].join(" • ");
}


/*************************************************
 * FIND MONTH BLOCKS
 *
 * Searches the calendar for month labels such as:
 *
 * JULY
 * 2026
 *************************************************/

function weeklyOSFindProductionCalendarMonthBlocks_(
  displayValues
) {
  const blocks = [];

  for (
    let rowIndex = 0;
    rowIndex < displayValues.length;
    rowIndex++
  ) {
    const rowText =
      weeklyOSUpper_(
        displayValues[rowIndex]
          .join(" ")
      );

    const monthMatch =
      rowText.match(
        /\b(JANUARY|FEBRUARY|MARCH|APRIL|MAY|JUNE|JULY|AUGUST|SEPTEMBER|OCTOBER|NOVEMBER|DECEMBER)\b/
      );

    const yearMatch =
      rowText.match(
        /\b(20\d{2})\b/
      );

    if (
      !monthMatch ||
      !yearMatch
    ) {
      continue;
    }

    const monthNumber =
      weeklyOSMonthNameToNumber_(
        monthMatch[1]
      );

    blocks.push({
      headerRow:
        rowIndex,

      month:
        monthNumber,

      year:
        Number(
          yearMatch[1]
        )
    });
  }

  blocks.forEach(
    function (block, index) {
      block.endRow =
        index < blocks.length - 1
          ? blocks[index + 1]
              .headerRow - 1
          : displayValues.length - 1;
    }
  );

  return blocks;
}


/*************************************************
 * PARSE ONE PRODUCTION CALENDAR MONTH
 *************************************************/

function weeklyOSParseProductionCalendarMonth_(
  draft,
  displayValues,
  fontColors,
  monthBlock,
  peopleIndex
) {
  const result = {
    castOutCount: 0,
    companyEventCount: 0,
    holidayCount: 0,
    noteCount: 0
  };

  const startRow =
    monthBlock.headerRow;

  const endRow =
    monthBlock.endRow;

  for (
    let rowIndex = startRow;
    rowIndex <= endRow;
    rowIndex++
  ) {
    for (
      let columnIndex = 0;
      columnIndex <
      displayValues[rowIndex].length;
      columnIndex++
    ) {
      const cellText =
        weeklyOSNormalizeText_(
          displayValues[rowIndex]
            [columnIndex]
        );

      if (
        !/^\d{1,2}$/.test(
          cellText
        )
      ) {
        continue;
      }

      const dayNumber =
        Number(cellText);

      if (
        dayNumber < 1 ||
        dayNumber > 31
      ) {
        continue;
      }

      const date =
        new Date(
          monthBlock.year,
          monthBlock.month - 1,
          dayNumber
        );

      if (
        date.getMonth() !==
        monthBlock.month - 1
      ) {
        continue;
      }

      if (
        !weeklyOSDateIsWithinRange_(
          date,
          draft.weekStart,
          draft.weekEnd
        )
      ) {
        continue;
      }

      const nextDateRow =
        weeklyOSFindNextProductionDateRow_(
          displayValues,
          rowIndex,
          columnIndex,
          endRow
        );

      const contentStartRow =
        rowIndex + 1;

      const contentEndRow =
        nextDateRow === null
          ? Math.min(
              rowIndex + 8,
              endRow
            )
          : nextDateRow - 1;

      const parsed =
        weeklyOSParseProductionCalendarDayCell_(
          draft,
          date,
          displayValues,
          fontColors,
          columnIndex,
          contentStartRow,
          contentEndRow,
          peopleIndex
        );

      result.castOutCount +=
        parsed.castOutCount;

      result.companyEventCount +=
        parsed.companyEventCount;

      result.holidayCount +=
        parsed.holidayCount;

      result.noteCount +=
        parsed.noteCount;
    }
  }

  return result;
}


/*************************************************
 * FIND NEXT DATE NUMBER IN SAME COLUMN
 *************************************************/

function weeklyOSFindNextProductionDateRow_(
  displayValues,
  currentRow,
  columnIndex,
  endRow
) {
  for (
    let rowIndex =
      currentRow + 1;
    rowIndex <= endRow;
    rowIndex++
  ) {
    const value =
      weeklyOSNormalizeText_(
        displayValues[rowIndex]
          [columnIndex]
      );

    if (
      /^\d{1,2}$/.test(value)
    ) {
      return rowIndex;
    }
  }

  return null;
}


/*************************************************
 * PARSE PRODUCTION CALENDAR DAY CELL
 *************************************************/

function weeklyOSParseProductionCalendarDayCell_(
  draft,
  date,
  displayValues,
  fontColors,
  columnIndex,
  startRow,
  endRow,
  peopleIndex
) {
  const result = {
    castOutCount: 0,
    companyEventCount: 0,
    holidayCount: 0,
    noteCount: 0
  };

  const day =
    weeklyOSGetDay_(
      draft,
      date
    );

  if (!day) {
    return result;
  }

  for (
    let rowIndex = startRow;
    rowIndex <= endRow;
    rowIndex++
  ) {
    const text =
      weeklyOSNormalizeText_(
        displayValues[rowIndex]
          [columnIndex]
      );

    if (!text) {
      continue;
    }

    if (
      /^\d{1,2}$/.test(text)
    ) {
      break;
    }

    const upper =
      weeklyOSUpper_(
        text
      );

    const color =
      weeklyOSUpper_(
        fontColors[rowIndex]
          [columnIndex]
      );

    day.sources
      .productionCalendar = true;

    if (
      upper.indexOf(
        "PERFORMANCE"
      ) >= 0 ||
      weeklyOSLooksLikeTime_(text) ||
      upper.indexOf(
        "UNDERSTUDY REH"
      ) >= 0 ||
      upper.indexOf(
        "WORK CALL"
      ) >= 0 ||
      upper.indexOf(
        "AEA DAY OFF"
      ) >= 0
    ) {
      continue;
    }

    if (
      upper.indexOf(
        "OUT"
      ) >= 0
    ) {
      const outItems =
        weeklyOSParseProductionCastOutText_(
          text,
          peopleIndex,
          rowIndex + 1
        );

      outItems.forEach(
        function (outItem) {
          day.castOuts.push(
            outItem
          );

          result.castOutCount++;
        }
      );

      continue;
    }

    const companyEvent =
      weeklyOSParseCompanyEventText_(
        text,
        rowIndex + 1
      );

    if (companyEvent) {
      day.companyEvents.push(
        companyEvent
      );

      result.companyEventCount++;
      continue;
    }

    if (
      weeklyOSLooksLikeHoliday_(
        text
      )
    ) {
      day.holidays.push(
        weeklyOSCreateHoliday_({
          title:
            text,

          source:
            "Production Calendar",

          sourceRow:
            rowIndex + 1
        })
      );

      result.holidayCount++;
      continue;
    }

    if (
      weeklyOSIsProductionCalendarDecorativeText_(
        text
      )
    ) {
      continue;
    }

    day.notes.push(
      weeklyOSCreateNote_({
        text:
          text,

        category:
          color.indexOf(
            "0000FF"
          ) >= 0
            ? "COMPANY"
            : "CALENDAR",

        source:
          "Production Calendar",

        sourceRow:
          rowIndex + 1
      })
    );

    result.noteCount++;
  }

  return result;
}


/*************************************************
 * PARSE PRODUCTION CALENDAR CAST OUT
 *************************************************/

function weeklyOSParseProductionCastOutText_(
  text,
  peopleIndex,
  sourceRow
) {
  const results = [];

  String(text)
    .split(
      /\n|,|;/
    )
    .map(
      weeklyOSNormalizeText_
    )
    .filter(Boolean)
    .forEach(
      function (segment) {
        const match =
          segment.match(
            /^(.+?)\s+OUT\b/i
          );

        if (!match) {
          return;
        }

        const enteredName =
          weeklyOSNormalizeText_(
            match[1]
          );

        const resolved =
          weeklyOSResolvePerson_(
            enteredName,
            peopleIndex
          );

        results.push(
          weeklyOSCreateOut_({
            category:
              "CAST",

            person:
              resolved.fullName ||
              enteredName,

            role:
              resolved.role ||
              "",

            appliesTo:
              "ALL",

            requiresReview:
              true,

            sources: [
              "Production Calendar"
            ],

            sourceRows: [
              sourceRow
            ]
          })
        );
      }
    );

  return results;
}


/*************************************************
 * COMPANY EVENT PARSER
 *************************************************/

function weeklyOSParseCompanyEventText_(
  text,
  sourceRow
) {
  const upper =
    weeklyOSUpper_(
      text
    );

  let type = "";

  if (
    upper.indexOf(
      "START DATE"
    ) >= 0
  ) {
    type =
      "NEW_HIRE_START";
  } else if (
    upper.indexOf(
      "FIRST PERFORMANCE"
    ) >= 0
  ) {
    type =
      "FIRST_PERFORMANCE";
  } else if (
    upper.indexOf(
      "SCHEDULED RETURN"
    ) >= 0 ||
    upper.indexOf(
      "RETURN"
    ) >= 0
  ) {
    type =
      "SCHEDULED_RETURN";
  } else if (
    upper.indexOf(
      "FINAL PERFORMANCE"
    ) >= 0
  ) {
    type =
      "FINAL_PERFORMANCE";
  } else if (
    upper.indexOf(
      "WATCH SHOW"
    ) >= 0
  ) {
    type =
      "WATCH_SHOW";
  } else if (
    upper.indexOf(
      "ONBOARDING"
    ) >= 0 ||
    upper.indexOf(
      "MEASUREMENTS"
    ) >= 0
  ) {
    type =
      "ONBOARDING";
  } else if (
    upper.indexOf(
      "BROADWAY IN BRYANT PARK"
    ) >= 0
  ) {
    type =
      "SPECIAL_EVENT";
  } else if (
    upper.indexOf(
      "MEETING"
    ) >= 0
  ) {
    type =
      "COMPANY_MEETING";
  } else if (
    upper.indexOf(
      "GUEST SPELLER"
    ) >= 0
  ) {
    type =
      "SPECIAL_EVENT";
  }

  if (!type) {
    return null;
  }

  return weeklyOSCreateCompanyEvent_({
    type:
      type,

    title:
      text,

    people:
      weeklyOSExtractPeopleFromCompanyEvent_(
        text,
        type
      ),

    requiresReview:
      (
        type ===
          "NEW_HIRE_START" ||
        type ===
          "SPECIAL_EVENT"
      ),

    source:
      "Production Calendar",

    sourceRow:
      sourceRow
  });
}


/*************************************************
 * EXTRACT PEOPLE FROM COMPANY EVENT
 *************************************************/

function weeklyOSExtractPeopleFromCompanyEvent_(
  text,
  type
) {
  let cleaned =
    weeklyOSNormalizeText_(
      text
    );

  const phrases = [
    "START DATE",
    "FIRST PERFORMANCE",
    "SCHEDULED RETURN",
    "FINAL PERFORMANCE",
    "WATCH SHOW",
    "ONBOARDING",
    "MEASUREMENTS"
  ];

  phrases.forEach(
    function (phrase) {
      cleaned =
        cleaned.replace(
          new RegExp(
            phrase,
            "ig"
          ),
          ""
        );
    }
  );

  if (
    type === "SPECIAL_EVENT" ||
    type === "COMPANY_MEETING"
  ) {
    return [];
  }

  return cleaned
    .split(
      /\s*\+\s*|\s*&\s*|,\s*/
    )
    .map(
      weeklyOSNormalizeText_
    )
    .filter(Boolean);
}


/*************************************************
 * PD / VACATION TRACKER
 *
 * Confirmed layout:
 *
 * A = Actor
 * B = Dates
 * C = # Performances
 * D = Request Status
 * E = Type
 * F = Reason
 *
 * Actor name is entered at the top of each block.
 * WeeklyOS carries the actor forward through
 * that person's dated rows.
 *************************************************/

function weeklyOSReadPdVacationTracker_(
  draft,
  peopleIndex
) {
  const config =
    weeklyOSGetConfig_();

  const status =
    draft.sourceStatus
      .pdVacationTracker;

  status.checkedAt =
    weeklyOSNowIso_();

  const sheet =
    weeklyOSGetSheetSafe_(
      config.sheets
        .pdVacationTracker
    );

  if (!sheet) {
    status.status =
      "NOT_FOUND";

    status.details =
      'Sheet "' +
      config.sheets
        .pdVacationTracker +
      '" was not found.';

    return;
  }

  status.found = true;
  status.status = "FOUND";

  const lastRow =
    sheet.getLastRow();

  if (lastRow < 5) {
    status.details =
      "PD/Vacation Tracker contains no request rows.";

    return;
  }

  const rawValues =
    sheet
      .getRange(
        5,
        1,
        lastRow - 4,
        6
      )
      .getValues();

  const displayValues =
    sheet
      .getRange(
        5,
        1,
        lastRow - 4,
        6
      )
      .getDisplayValues();

  let currentActor = "";

  let enrichedCount = 0;
  let createdCount = 0;

  for (
    let index = 0;
    index < rawValues.length;
    index++
  ) {
    const rowNumber =
      index + 5;

    const displayRow =
      displayValues[index];

    const rawRow =
      rawValues[index];

    const actorCell =
      weeklyOSNormalizeText_(
        displayRow[0]
      );

    if (
      actorCell &&
      !weeklyOSLooksLikeDate_(
        actorCell
      )
    ) {
      currentActor =
        actorCell;
    }

    const date =
      weeklyOSAsDate_(
        rawRow[1]
      ) ||
      weeklyOSAsDate_(
        displayRow[1]
      );

    if (
      !currentActor ||
      !date
    ) {
      continue;
    }

    if (
      !weeklyOSDateIsWithinRange_(
        date,
        draft.weekStart,
        draft.weekEnd
      )
    ) {
      continue;
    }

    const day =
      weeklyOSGetDay_(
        draft,
        date
      );

    if (!day) {
      continue;
    }

    const resolved =
      weeklyOSResolvePerson_(
        currentActor,
        peopleIndex
      );

    const fullName =
      resolved.fullName ||
      currentActor;

    const numberOfPerformances =
      weeklyOSNumberOrNull_(
        rawRow[2]
      );

    const approvalStatus =
      weeklyOSNormalizeText_(
        displayRow[3]
      );

    const type =
      weeklyOSNormalizeText_(
        displayRow[4]
      );

    const reason =
      weeklyOSNormalizeText_(
        displayRow[5]
      );

    const existing =
      weeklyOSFindMatchingOut_(
        day.castOuts,
        fullName
      );

    if (existing) {
      existing.role =
        existing.role ||
        resolved.role ||
        "";

      existing.numberOfPerformances =
        numberOfPerformances;

      existing.approvalStatus =
        approvalStatus;

      existing.type =
        type;

      existing.reason =
        reason;

      existing.sources =
        weeklyOSUniqueStrings_(
          existing.sources.concat([
            "PD/Vacation Tracker"
          ])
        );

      existing.sourceRows =
        weeklyOSUniqueNumbers_(
          existing.sourceRows.concat([
            rowNumber
          ])
        );

      enrichedCount++;
    } else {
      day.castOuts.push(
        weeklyOSCreateOut_({
          category:
            "CAST",

          person:
            fullName,

          role:
            resolved.role ||
            "",

          type:
            type,

          reason:
            reason,

          approvalStatus:
            approvalStatus,

          numberOfPerformances:
            numberOfPerformances,

          appliesTo:
            "ALL",

          requiresReview:
            true,

          sources: [
            "PD/Vacation Tracker"
          ],

          sourceRows: [
            rowNumber
          ]
        })
      );

      createdCount++;
    }

    day.sources
      .pdVacationTracker = true;
  }

  status.details =
    enrichedCount +
    " cast out(s) enriched • " +
    createdCount +
    " tracker-only out(s) created.";
}



/*************************************************
 * CONTACT SHEET
 *
 * This reader intentionally uses flexible header
 * detection because Contact Sheet layouts may vary.
 *
 * It builds an internal people index used to resolve:
 *
 * Justin → Justin Cooley
 * Kevin → Kevin McHale
 * Mia → Mia Wilson
 *
 * It also stores role / track / department data.
 *************************************************/

function weeklyOSReadContactSheet_(
  draft
) {
  const config =
    weeklyOSGetConfig_();

  const status =
    draft.sourceStatus
      .contactSheet;

  status.checkedAt =
    weeklyOSNowIso_();

  const index =
    weeklyOSCreatePeopleIndex_();

  const sheet =
    weeklyOSGetSheetSafe_(
      config.sheets
        .contactSheet
    );

  if (!sheet) {
    status.status =
      "NOT_FOUND";

    status.details =
      'Sheet "' +
      config.sheets
        .contactSheet +
      '" was not found.';

    return index;
  }

  status.found = true;
  status.status = "FOUND";

  const displayValues =
    sheet
      .getDataRange()
      .getDisplayValues();

  const header =
    weeklyOSFindContactSheetHeaders_(
      displayValues
    );

  let personCount = 0;

  for (
    let rowIndex =
      header.headerRow + 1;
    rowIndex <
      displayValues.length;
    rowIndex++
  ) {
    const row =
      displayValues[rowIndex];

    const name =
      weeklyOSNormalizeText_(
        row[header.nameColumn]
      );

    if (!name) {
      continue;
    }

    const title =
      header.titleColumn >= 0
        ? weeklyOSNormalizeText_(
            row[
              header.titleColumn
            ]
          )
        : "";

    const department =
      header.departmentColumn >= 0
        ? weeklyOSNormalizeText_(
            row[
              header.departmentColumn
            ]
          )
        : "";

    const email =
      header.emailColumn >= 0
        ? weeklyOSNormalizeText_(
            row[
              header.emailColumn
            ]
          )
        : "";

    weeklyOSAddPersonToIndex_(
      index,
      {
        fullName:
          name,

        role:
          title,

        department:
          department,

        email:
          email,

        sourceRow:
          rowIndex + 1
      }
    );

    personCount++;
  }

  status.details =
    personCount +
    " contact record(s) indexed.";

  return index;
}


/*************************************************
 * FIND CONTACT SHEET HEADERS
 *************************************************/

function weeklyOSFindContactSheetHeaders_(
  values
) {
  const result = {
    headerRow: 0,
    nameColumn: 0,
    titleColumn: -1,
    departmentColumn: -1,
    emailColumn: -1
  };

  let bestScore = -1;

  for (
    let rowIndex = 0;
    rowIndex <
      Math.min(
        values.length,
        25
      );
    rowIndex++
  ) {
    const row =
      values[rowIndex]
        .map(
          weeklyOSUpper_
        );

    let score = 0;

    const nameColumn =
      weeklyOSFindColumnByKeywords_(
        row,
        [
          "NAME",
          "EMPLOYEE",
          "CAST",
          "CREW"
        ]
      );

    const titleColumn =
      weeklyOSFindColumnByKeywords_(
        row,
        [
          "TITLE",
          "ROLE",
          "TRACK",
          "POSITION"
        ]
      );

    const departmentColumn =
      weeklyOSFindColumnByKeywords_(
        row,
        [
          "DEPARTMENT",
          "DEPT"
        ]
      );

    const emailColumn =
      weeklyOSFindColumnByKeywords_(
        row,
        [
          "EMAIL",
          "E-MAIL"
        ]
      );

    if (nameColumn >= 0) {
      score += 4;
    }

    if (titleColumn >= 0) {
      score += 2;
    }

    if (departmentColumn >= 0) {
      score += 2;
    }

    if (emailColumn >= 0) {
      score += 1;
    }

    if (score > bestScore) {
      bestScore =
        score;

      result.headerRow =
        rowIndex;

      result.nameColumn =
        nameColumn >= 0
          ? nameColumn
          : 0;

      result.titleColumn =
        titleColumn;

      result.departmentColumn =
        departmentColumn;

      result.emailColumn =
        emailColumn;
    }
  }

  return result;
}


/*************************************************
 * PEOPLE INDEX
 *************************************************/

function weeklyOSCreatePeopleIndex_() {
  return {
    byFullName: {},
    byFirstName: {},
    byLastName: {},
    all: []
  };
}


function weeklyOSAddPersonToIndex_(
  index,
  person
) {
  const fullName =
    weeklyOSNormalizeText_(
      person.fullName
    );

  if (!fullName) {
    return;
  }

  const parts =
    fullName.split(
      /\s+/
    );

  const firstName =
    parts[0] || "";

  const lastName =
    parts.length > 1
      ? parts[
          parts.length - 1
        ]
      : "";

  const record = {
    fullName:
      fullName,

    firstName:
      firstName,

    lastName:
      lastName,

    role:
      weeklyOSNormalizeText_(
        person.role
      ),

    department:
      weeklyOSNormalizeText_(
        person.department
      ),

    email:
      weeklyOSNormalizeText_(
        person.email
      ),

    sourceRow:
      person.sourceRow ||
      null
  };

  index.byFullName[
    weeklyOSUpper_(
      fullName
    )
  ] = record;

  if (firstName) {
    const firstKey =
      weeklyOSUpper_(
        firstName
      );

    if (
      !index.byFirstName[
        firstKey
      ]
    ) {
      index.byFirstName[
        firstKey
      ] = [];
    }

    index.byFirstName[
      firstKey
    ].push(
      record
    );
  }

  if (lastName) {
    const lastKey =
      weeklyOSUpper_(
        lastName
      );

    if (
      !index.byLastName[
        lastKey
      ]
    ) {
      index.byLastName[
        lastKey
      ] = [];
    }

    index.byLastName[
      lastKey
    ].push(
      record
    );
  }

  index.all.push(
    record
  );
}


function weeklyOSResolvePerson_(
  enteredName,
  peopleIndex
) {
  const blank = {
    fullName:
      weeklyOSNormalizeText_(
        enteredName
      ),

    role: "",
    department: "",
    email: ""
  };

  if (
    !peopleIndex ||
    !enteredName
  ) {
    return blank;
  }

  const normalized =
    weeklyOSNormalizeText_(
      enteredName
    );

  const upper =
    weeklyOSUpper_(
      normalized
    );

  if (
    peopleIndex.byFullName[
      upper
    ]
  ) {
    return peopleIndex
      .byFullName[
        upper
      ];
  }

  const firstName =
    normalized.split(
      /\s+/
    )[0];

  const firstMatches =
    peopleIndex.byFirstName[
      weeklyOSUpper_(
        firstName
      )
    ] || [];

  if (
    firstMatches.length === 1
  ) {
    return firstMatches[0];
  }

  const startsWithMatches =
    peopleIndex.all.filter(
      function (person) {
        return (
          weeklyOSUpper_(
            person.fullName
          ).indexOf(
            upper
          ) === 0
        );
      }
    );

  if (
    startsWithMatches.length === 1
  ) {
    return startsWithMatches[0];
  }

  return blank;
}


/*************************************************
 * ENRICH OUTS FROM PEOPLE INDEX
 *
 * Contact Sheet remains the general people source.
 * Cast List is the canonical cast-role fallback.
 *************************************************/

function weeklyOSEnrichOutsFromPeopleIndex_(
  draft,
  peopleIndex
) {
  const castRoleByPerson =
    weeklyOSGetCastRoleByPerson_();

  draft.days.forEach(
    function (day) {
      day.castOuts.forEach(
        function (outItem) {
          const resolved =
            weeklyOSResolvePerson_(
              outItem.person,
              peopleIndex
            );

          outItem.person =
            resolved.fullName ||
            outItem.person;

          const personKey =
            weeklyOSUpper_(
              outItem.person
            );

          outItem.role =
            outItem.role ||
            castRoleByPerson[
              personKey
            ] ||
            resolved.role ||
            "";
        }
      );

      day.crewOuts.forEach(
        function (outItem) {
          const resolved =
            weeklyOSResolvePerson_(
              outItem.person,
              peopleIndex
            );

          outItem.person =
            resolved.fullName ||
            outItem.person;

          outItem.department =
            outItem.department ||
            resolved.department ||
            resolved.role ||
            "";
        }
      );
    }
  );
}


/*************************************************
 * CAST ROLE BY PERSON
 *
 * Cast List:
 * B = Full Name
 * D = Full Character
 * E = Short Role
 *************************************************/

function weeklyOSGetCastRoleByPerson_() {
  const result = {};

  const sheet =
    weeklyOSGetSheetSafe_(
      "Cast List"
    );

  if (!sheet) {
    return result;
  }

  const lastRow =
    sheet.getLastRow();

  if (lastRow < 3) {
    return result;
  }

  const values =
    sheet
      .getRange(
        3,
        1,
        lastRow - 2,
        6
      )
      .getDisplayValues();

  values.forEach(function (row) {
    const fullName =
      weeklyOSNormalizeText_(
        row[1]
      );

    const shortRole =
      weeklyOSNormalizeText_(
        row[4] ||
        row[0]
      );

    const fullCharacter =
      weeklyOSNormalizeText_(
        row[3]
      );

    if (!fullName) {
      return;
    }

    const role =
      shortRole ||
      fullCharacter;

    if (!role) {
      return;
    }

    result[
      weeklyOSUpper_(
        fullName
      )
    ] = role;
  });

  return result;
}

/*************************************************
 * PRESERVE MANUAL DRAFT EDITS
 *************************************************/

function weeklyOSMergeManualDraftEdits_(
  refreshedDraft,
  currentDraft
) {
  refreshedDraft.days.forEach(
    function (newDay) {
      const oldDay =
        weeklyOSGetDay_(
          currentDraft,
          newDay.date
        );

      if (!oldDay) {
        return;
      }

      newDay.reviewed =
        Boolean(
          oldDay.reviewed
        );

      newDay.rehearsals =
        weeklyOSMergeManualItems_(
          newDay.rehearsals,
          oldDay.rehearsals
        );

      newDay.meetings =
        weeklyOSMergeManualItems_(
          newDay.meetings,
          oldDay.meetings
        );

      newDay.workCalls =
        weeklyOSMergeManualItems_(
          newDay.workCalls,
          oldDay.workCalls
        );

      newDay.putIns =
        weeklyOSMergeManualItems_(
          newDay.putIns,
          oldDay.putIns
        );

      newDay.companyEvents =
        weeklyOSMergeManualItems_(
          newDay.companyEvents,
          oldDay.companyEvents
        );

      newDay.notes =
        weeklyOSMergeManualItems_(
          newDay.notes,
          oldDay.notes
        );

      weeklyOSPreserveOutSelections_(
        newDay.castOuts,
        oldDay.castOuts
      );

      weeklyOSPreserveOutSelections_(
        newDay.crewOuts,
        oldDay.crewOuts
      );
    }
  );
}


function weeklyOSMergeManualItems_(
  sourceItems,
  oldItems
) {
  const merged =
    Array.isArray(
      sourceItems
    )
      ? sourceItems.slice()
      : [];

  (
    Array.isArray(oldItems)
      ? oldItems
      : []
  ).forEach(
    function (item) {
      if (
        item.source !==
        "Manual"
      ) {
        return;
      }

      merged.push(
        item
      );
    }
  );

  return merged;
}


function weeklyOSPreserveOutSelections_(
  newOuts,
  oldOuts
) {
  (
    Array.isArray(newOuts)
      ? newOuts
      : []
  ).forEach(
    function (newItem) {
      const oldItem =
        (
          Array.isArray(oldOuts)
            ? oldOuts
            : []
        ).find(
          function (candidate) {
            return (
              weeklyOSUpper_(
                candidate.person
              ) ===
              weeklyOSUpper_(
                newItem.person
              )
            );
          }
        );

      if (!oldItem) {
        return;
      }

      newItem.coverage =
        oldItem.coverage ||
        newItem.coverage;

      newItem.appliesTo =
        oldItem.appliesTo ||
        newItem.appliesTo;

      newItem.appliesToRehearsal =
        Boolean(
          oldItem
            .appliesToRehearsal
        );

      newItem.appliesToPutIn =
        Boolean(
          oldItem
            .appliesToPutIn
        );

      if (newItem.coverage) {
        newItem.requiresReview =
          false;
      }
    }
  );
}


/*************************************************
 * DEDUPLICATE DRAFT DATA
 *************************************************/

function weeklyOSDeduplicateDraftSources_(
  draft
) {
  draft.days.forEach(
    function (day) {
      day.performances =
        weeklyOSDeduplicateByKey_(
          day.performances,
          function (item) {
            return [
              item.performanceNumber,
              item.time
            ].join("|");
          }
        );

      day.rehearsals =
        weeklyOSDeduplicateByKey_(
          day.rehearsals,
          function (item) {
            return [
              item.title,
              item.startTime,
              item.endTime
            ].join("|");
          }
        );

      day.putIns =
        weeklyOSDeduplicateByKey_(
          day.putIns,
          function (item) {
            return [
              item.title,
              item.startTime,
              item.endTime
            ].join("|");
          }
        );

      day.castOuts =
        weeklyOSMergeDuplicateOuts_(
          day.castOuts
        );

      day.crewOuts =
        weeklyOSMergeDuplicateOuts_(
          day.crewOuts
        );

      day.pt =
        weeklyOSDeduplicateByKey_(
          day.pt,
          function (item) {
            return [
              item.startTime,
              item.endTime,
              item.location
            ].join("|");
          }
        );

      day.companyEvents =
        weeklyOSDeduplicateByKey_(
          day.companyEvents,
          function (item) {
            return [
              item.type,
              item.title
            ].join("|");
          }
        );

      day.notes =
        weeklyOSDeduplicateByKey_(
          day.notes,
          function (item) {
            return item.text;
          }
        );
    }
  );
}


function weeklyOSMergeDuplicateOuts_(
  outs
) {
  const byPerson = {};

  (
    Array.isArray(outs)
      ? outs
      : []
  ).forEach(
    function (item) {
      const key =
        weeklyOSUpper_(
          item.person
        );

      if (!key) {
        return;
      }

      if (!byPerson[key]) {
        byPerson[key] =
          item;

        return;
      }

      const existing =
        byPerson[key];

      existing.role =
        existing.role ||
        item.role ||
        "";

      existing.department =
        existing.department ||
        item.department ||
        "";

      existing.type =
        existing.type ||
        item.type ||
        "";

      existing.reason =
        existing.reason ||
        item.reason ||
        "";

      existing.approvalStatus =
        existing.approvalStatus ||
        item.approvalStatus ||
        "";

      existing.numberOfPerformances =
        existing.numberOfPerformances != null
          ? existing.numberOfPerformances
          : item.numberOfPerformances;

      existing.coverage =
        existing.coverage ||
        item.coverage ||
        "";

      existing.sources =
        weeklyOSUniqueStrings_(
          []
            .concat(
              existing.sources || []
            )
            .concat(
              item.sources || []
            )
        );

      existing.sourceRows =
        weeklyOSUniqueNumbers_(
          []
            .concat(
              existing.sourceRows || []
            )
            .concat(
              item.sourceRows || []
            )
        );
    }
  );

  return Object.keys(
    byPerson
  ).map(
    function (key) {
      return byPerson[key];
    }
  );
}


/*************************************************
 * GENERAL SOURCE HELPERS
 *************************************************/

function weeklyOSExtractPerformanceNumber_(
  text
) {
  const match =
    String(text || "")
      .match(
        /PERFORMANCE\s*#?\s*(\d+)/i
      );

  return match
    ? match[1]
    : "";
}


function weeklyOSDetermineShowType_(
  time,
  label
) {
  const combined =
    weeklyOSUpper_(
      [
        time,
        label
      ]
        .filter(Boolean)
        .join(" ")
    );

  if (
    combined.indexOf(
      "MAT"
    ) >= 0
  ) {
    return "MAT";
  }

  if (
    combined.indexOf(
      "EVE"
    ) >= 0
  ) {
    return "EVE";
  }

  const parsedHour =
    weeklyOSExtractHour_(
      time
    );

  if (
    parsedHour !== null &&
    parsedHour < 5
  ) {
    return "MAT";
  }

  return "EVE";
}


function weeklyOSDetermineRehearsalType_(
  title
) {
  const upper =
    weeklyOSUpper_(
      title
    );

  if (
    upper.indexOf(
      "UNDERSTUDY"
    ) >= 0
  ) {
    return "UNDERSTUDY";
  }

  if (
    upper.indexOf(
      "NEW "
    ) >= 0 ||
    upper.indexOf(
      "NEW-HIRE"
    ) >= 0 ||
    upper.indexOf(
      "NEW HIRE"
    ) >= 0
  ) {
    return "NEW_HIRE";
  }

  if (
    upper.indexOf(
      "BRUSH"
    ) >= 0
  ) {
    return "BRUSH_UP";
  }

  if (
    upper.indexOf(
      "MUSIC"
    ) >= 0
  ) {
    return "MUSIC_REVIEW";
  }

  if (
    upper.indexOf(
      "DANCE"
    ) >= 0
  ) {
    return "DANCE_REVIEW";
  }

  return "OTHER";
}


function weeklyOSParseTimeRange_(
  value
) {
  const text =
    weeklyOSNormalizeText_(
      value
    );

  const result = {
    startTime: "",
    endTime: "",
    location: ""
  };

  if (!text) {
    return result;
  }

  const locationMatch =
    text.match(
      /\(([^)]+)\)/
    );

  if (locationMatch) {
    result.location =
      weeklyOSNormalizeText_(
        locationMatch[1]
      );
  }

  const cleaned =
    text.replace(
      /\([^)]+\)/g,
      ""
    );

  const pieces =
    cleaned.split(
      /\s*[-–—]\s*/
    );

  if (pieces.length >= 2) {
    result.startTime =
      weeklyOSNormalizeText_(
        pieces[0]
      );

    result.endTime =
      weeklyOSNormalizeText_(
        pieces[1]
      );
  } else {
    result.startTime =
      weeklyOSNormalizeText_(
        cleaned
      );
  }

  return result;
}


function weeklyOSExtractHour_(
  timeText
) {
  const match =
    weeklyOSNormalizeText_(
      timeText
    ).match(
      /^(\d{1,2})(?::\d{2})?\s*(AM|PM)?/i
    );

  if (!match) {
    return null;
  }

  let hour =
    Number(
      match[1]
    );

  const meridiem =
    weeklyOSUpper_(
      match[2]
    );

  if (
    meridiem === "PM" &&
    hour !== 12
  ) {
    hour += 12;
  }

  if (
    meridiem === "AM" &&
    hour === 12
  ) {
    hour = 0;
  }

  return hour;
}


function weeklyOSLooksLikeTime_(
  value
) {
  return (
    /\b\d{1,2}:\d{2}\s*(AM|PM)?\b/i.test(
      String(value || "")
    )
  );
}


function weeklyOSLooksLikeDate_(
  value
) {
  return Boolean(
    weeklyOSAsDate_(
      value
    )
  );
}


function weeklyOSLooksLikeHoliday_(
  value
) {
  const upper =
    weeklyOSUpper_(
      value
    );

  const keywords = [
    "HOLIDAY",
    "INDEPENDENCE DAY",
    "MEMORIAL DAY",
    "LABOR DAY",
    "THANKSGIVING",
    "CHRISTMAS",
    "NEW YEAR"
  ];

  return keywords.some(
    function (keyword) {
      return (
        upper.indexOf(
          keyword
        ) >= 0
      );
    }
  );
}


function weeklyOSIsProductionCalendarDecorativeText_(
  value
) {
  const upper =
    weeklyOSUpper_(
      value
    );

  const decorativeKeywords = [
    "BLACK OUT DAYS",
    "BLACKOUT DAYS",
    "ON CONTRACT",
    "VACATION SWING",
    "PRESENTING"
  ];

  return decorativeKeywords.some(
    function (keyword) {
      return (
        upper.indexOf(
          keyword
        ) >= 0
      );
    }
  );
}


function weeklyOSMonthNameToNumber_(
  monthName
) {
  const months = {
    JANUARY: 1,
    FEBRUARY: 2,
    MARCH: 3,
    APRIL: 4,
    MAY: 5,
    JUNE: 6,
    JULY: 7,
    AUGUST: 8,
    SEPTEMBER: 9,
    OCTOBER: 10,
    NOVEMBER: 11,
    DECEMBER: 12
  };

  return (
    months[
      weeklyOSUpper_(
        monthName
      )
    ] || 0
  );
}


function weeklyOSFindColumnByKeywords_(
  normalizedRow,
  keywords
) {
  for (
    let columnIndex = 0;
    columnIndex <
      normalizedRow.length;
    columnIndex++
  ) {
    const cell =
      normalizedRow[
        columnIndex
      ];

    for (
      let keywordIndex = 0;
      keywordIndex <
        keywords.length;
      keywordIndex++
    ) {
      const keyword =
        weeklyOSUpper_(
          keywords[
            keywordIndex
          ]
        );

      if (
        cell === keyword ||
        cell.indexOf(
          keyword
        ) >= 0
      ) {
        return columnIndex;
      }
    }
  }

  return -1;
}


function weeklyOSFindMatchingOut_(
  outs,
  personName
) {
  const upperName =
    weeklyOSUpper_(
      personName
    );

  return (
    Array.isArray(outs)
      ? outs
      : []
  ).find(
    function (item) {
      return (
        weeklyOSUpper_(
          item.person
        ) === upperName
      );
    }
  ) || null;
}


function weeklyOSNumberOrNull_(
  value
) {
  if (
    value === "" ||
    value == null
  ) {
    return null;
  }

  const number =
    Number(value);

  return isNaN(number)
    ? null
    : number;
}


function weeklyOSUniqueNumbers_(
  values
) {
  const seen = {};

  return (
    Array.isArray(values)
      ? values
      : []
  ).filter(
    function (value) {
      const number =
        Number(value);

      if (
        isNaN(number) ||
        seen[number]
      ) {
        return false;
      }

      seen[number] =
        true;

      return true;
    }
  );
}


function weeklyOSDeduplicateByKey_(
  items,
  keyBuilder
) {
  const seen = {};

  return (
    Array.isArray(items)
      ? items
      : []
  ).filter(
    function (item) {
      const key =
        weeklyOSUpper_(
          keyBuilder(item)
        );

      if (
        !key ||
        seen[key]
      ) {
        return false;
      }

      seen[key] =
        true;

      return true;
    }
  );
}



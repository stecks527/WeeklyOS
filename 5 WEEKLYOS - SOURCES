function weeklyOSBuildDraftSummary_(
  draft
) {
  return {
    weekStart:
      draft.weekStart,

    weekEnd:
      draft.weekEnd,

    days:
      draft.days.map(
        function (day) {
          return {
            date:
              day.date,

            performances:
              day.performances.length,

            rehearsals:
              day.rehearsals.length,

            putIns:
              day.putIns.length,

            workCalls:
              day.workCalls.length,

            castOuts:
              day.castOuts.length,

            crewOuts:
              day.crewOuts.length,

            companyEvents:
              day.companyEvents.length,

            pt:
              day.pt.length,

            status:
              day.status
          };
        }
      )
  };
}

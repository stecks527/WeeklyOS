  let draft =
    weeklyOSGetDraft();

  if (!draft) {
    draft =
      weeklyOSBuildDraft(
        weeklyOSNextMonday_()
      );
  }

  const template =
    HtmlService
      .createTemplateFromFile(
        "WeeklyOS Builder"
      );

  template.initialDraftJson =
    weeklyOSSafeJsonForHtml_(
      draft
    );

  template.initialBootstrapJson =
    weeklyOSSafeJsonForHtml_(
      weeklyOSBuildUiBootstrap_(
        draft
      )
    );

  const evaluated =
    template.evaluate();

  const content =
    evaluated.getContent();

  const result = {
    test:
      "WeeklyOS HTML Evaluation",

    htmlLength:
      content.length,

    containsWeeklyOS:
      content.indexOf(
        "WeeklyOS"
      ) >= 0,

    containsInitialDraft:
      content.indexOf(
        draft.id
      ) >= 0,

    passed:
      content.length > 1000 &&
      content.indexOf(
        draft.id
      ) >= 0
  };

  weeklyOSTestLog_(
    result
  );

  return result;
}



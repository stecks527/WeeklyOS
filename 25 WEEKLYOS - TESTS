/*************************************************
 * TEST 1 — SYSTEM CHECK
 *
 * Run this first.
 *
 * Confirms:
 * - Required WeeklyOS functions exist
 * - Required source sheets exist
 * - Configuration is readable
 * - HTML file can be found
 *************************************************/

function weeklyOSTest01SystemCheck() {
  const config =
    weeklyOSGetConfig_();

  const functionChecks = [
    {
      name:
        "WeeklyOS",

      exists:
        typeof WeeklyOS ===
        "function"
    },

    {
      name:
        "weeklyOSCreateWeekDraft_",

      exists:
        typeof weeklyOSCreateWeekDraft_ ===
        "function"
    },

    {
      name:
        "weeklyOSBuildDraft",

      exists:
        typeof weeklyOSBuildDraft ===
        "function"
    },

    {
      name:
        "weeklyOSRefreshDraft",

      exists:
        typeof weeklyOSRefreshDraft ===
        "function"
    },

    {
      name:
        "weeklyOSSaveDraft",

      exists:
        typeof weeklyOSSaveDraft ===
        "function"
    },

    {
      name:
        "weeklyOSGetDraft",

      exists:
        typeof weeklyOSGetDraft ===
        "function"
    },

    {
      name:
        "weeklyOSValidateDraft",

      exists:
        typeof weeklyOSValidateDraft ===
        "function"
    },

    {
      name:
        "weeklyOSOpenBuilder",

      exists:
        typeof weeklyOSOpenBuilder ===
        "function"
    }
  ];

  const sheetChecks = [
    {
      key:
        "expandedCalendar",

      configuredName:
        config.sheets
          .expandedCalendar
    },

    {
      key:
        "productionCalendar",

      configuredName:
        config.sheets
          .productionCalendar
    },

    {
      key:
        "pdVacationTracker",

      configuredName:
        config.sheets
          .pdVacationTracker
    },

    {
      key:
        "crewOuts",

      configuredName:
        config.sheets
          .crewOuts
    },

    {
      key:
        "contactSheet",

      configuredName:
        config.sheets
          .contactSheet
    },

    {
      key:
        "weeklyTemplate",

      configuredName:
        config.sheets
          .weeklyTemplate
    }
  ].map(
    function (item) {
      const sheet =
        weeklyOSGetSheetSafe_(
          item.configuredName
        );

      return {
        key:
          item.key,

        configuredName:
          item.configuredName,

        found:
          Boolean(sheet),

        rows:
          sheet
            ? sheet.getLastRow()
            : 0,

        columns:
          sheet
            ? sheet.getLastColumn()
            : 0
      };
    }
  );

  let htmlFound = false;
  let htmlError = "";

  try {
    HtmlService
      .createTemplateFromFile(
        "WeeklyOS Builder"
      );

    htmlFound = true;
  } catch (error) {
    htmlError =
      error.message;
  }

  const result = {
    test:
      "WeeklyOS System Check",

    version:
      config.version,

    functionChecks:
      functionChecks,

    sheetChecks:
      sheetChecks,

    html: {
      fileName:
        "WeeklyOS Builder",

      found:
        htmlFound,

      error:
        htmlError
    },

    passed:
      functionChecks.every(
        function (item) {
          return item.exists;
        }
      ) &&
      sheetChecks
        .filter(
          function (item) {
            return (
              item.key ===
                "expandedCalendar" ||
              item.key ===
                "productionCalendar" ||
              item.key ===
                "pdVacationTracker" ||
              item.key ===
                "crewOuts" ||
              item.key ===
                "contactSheet"
            );
          }
        )
        .every(
          function (item) {
            return item.found;
          }
        ) &&
      htmlFound
  };

  weeklyOSTestLog_(
    result
  );

  return result;
}



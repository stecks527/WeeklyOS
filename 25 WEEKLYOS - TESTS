/*************************************************
 * TEST 3 — CONTACT SHEET INDEX
 *
 * Reads Contact Sheet only.
 *
 * Reports:
 * - Detected header row
 * - Detected columns
 * - Number of people indexed
 * - Sample records
 *************************************************/

function weeklyOSTest03ContactSheetReader() {
  const config =
    weeklyOSGetConfig_();

  const sheet =
    weeklyOSAssertSheet_(
      config.sheets
        .contactSheet
    );

  const values =
    sheet
      .getDataRange()
      .getDisplayValues();

  const headers =
    weeklyOSFindContactSheetHeaders_(
      values
    );

  const draft =
    weeklyOSCreateWeekDraft_(
      weeklyOSNextMonday_()
    );

  const peopleIndex =
    weeklyOSReadContactSheet_(
      draft
    );

  const result = {
    test:
      "Contact Sheet Reader",

    sheet:
      sheet.getName(),

    detectedHeaderRow:
      headers.headerRow + 1,

    columns: {
      name:
        headers.nameColumn + 1,

      title:
        headers.titleColumn >= 0
          ? headers.titleColumn + 1
          : null,

      department:
        headers.departmentColumn >= 0
          ? headers.departmentColumn + 1
          : null,

      email:
        headers.emailColumn >= 0
          ? headers.emailColumn + 1
          : null
    },

    indexedPeople:
      peopleIndex.all.length,

    samples:
      peopleIndex.all
        .slice(0, 15),

    sourceStatus:
      draft.sourceStatus
        .contactSheet,

    passed:
      peopleIndex.all.length > 0
  };

  weeklyOSTestLog_(
    result
  );

  return result;
}



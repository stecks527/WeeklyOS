/*************************************************
 * RUN SAFE TEST SEQUENCE
 *
 * Runs Tests 1–11.
 *
 * It does not open the popup.
 * It does not generate a Weekly Schedule tab.
 *************************************************/

function weeklyOSTestRunSafeSequence() {
  const results = [];

  const tests = [
    weeklyOSTest01SystemCheck,
    weeklyOSTest02CreateEmptyModel,
    weeklyOSTest03ContactSheetReader,
    weeklyOSTest04ExpandedCalendarReader,
    weeklyOSTest05ProductionCalendarReader,
    weeklyOSTest06PdVacationReader,
    weeklyOSTest07CrewOutsReader,
    weeklyOSTest08BuildFullDraft,
    weeklyOSTest09Storage,
    weeklyOSTest10Validation,
    weeklyOSTest11HtmlEvaluation
  ];

  tests.forEach(
    function (
      testFunction
    ) {
      try {
        results.push(
          testFunction()
        );
      } catch (error) {
        results.push({
          test:
            testFunction.name,

          passed:
            false,

          error:
            error.message,

          stack:
            error.stack || ""
        });

        console.error(
          "[WeeklyOS Test Failure] " +
          testFunction.name +
          ": " +
          error.message
        );
      }
    }
  );

  const summary = {
    test:
      "WeeklyOS Safe Test Sequence",

    total:
      results.length,

    passed:
      results.filter(
        function (item) {
          return item.passed;
        }
      ).length,

    failed:
      results.filter(
        function (item) {
          return !item.passed;
        }
      ).length,

    results:
      results
  };

  weeklyOSTestLog_(
    summary
  );

  return summary;
}



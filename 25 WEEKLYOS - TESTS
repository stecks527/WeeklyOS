/*************************************************
 * TEST 13 — TEMPLATE / COMPOSITION ENGINE
 *
 * Composes the saved WeekModel without writing
 * anything to the Weekly Schedule template.
 *
 * Confirms:
 * - Composer functions exist
 * - Every day receives a template type
 * - Timeline rows and notes are created
 * - Guest Speller identities are removed
 * - Put-In assignments are populated
 * - New-actor styling metadata is available
 *************************************************/

function weeklyOSTest13TemplateEngine() {
  let draft =
    weeklyOSGetDraft();

  if (!draft) {
    draft =
      weeklyOSBuildDraft(
        weeklyOSNextMonday_()
      );
  }

  const requiredFunctions = [
    {
      name:
        "weeklyOSComposeDraft_",

      exists:
        typeof weeklyOSComposeDraft_ ===
        "function"
    },

    {
      name:
        "weeklyOSComposeDay_",

      exists:
        typeof weeklyOSComposeDay_ ===
        "function"
    },

    {
      name:
        "weeklyOSEnsurePutInAssignments_",

      exists:
        typeof weeklyOSEnsurePutInAssignments_ ===
        "function"
    },

    {
      name:
        "weeklyOSCreateRenderRow_",

      exists:
        typeof weeklyOSCreateRenderRow_ ===
        "function"
    },

    {
      name:
        "weeklyOSCreateRenderNote_",

      exists:
        typeof weeklyOSCreateRenderNote_ ===
        "function"
    }
  ];

  const missingFunctions =
    requiredFunctions.filter(
      function (item) {
        return !item.exists;
      }
    );

  if (missingFunctions.length) {
    throw new Error(
      "WeeklyOS composition test is missing required functions: " +
      missingFunctions
        .map(
          function (item) {
            return item.name;
          }
        )
        .join(", ")
    );
  }

  const composed =
    weeklyOSComposeDraft_(
      draft
    );

  const composedDays =
    composed.composition &&
    Array.isArray(
      composed.composition.days
    )
      ? composed.composition.days
      : [];

  const dayResults =
    composed.days.map(
      function (day) {
        const composedDay =
          composedDays.find(
            function (item) {
              return (
                item.date ===
                day.date
              );
            }
          ) || {};

        const performances =
          Array.isArray(
            day.performances
          )
            ? day.performances
            : [];

        const putIns =
          Array.isArray(
            day.putIns
          )
            ? day.putIns
            : [];

        return {
          date:
            day.date,

          templateType:
            day.templateType ||
            composedDay.templateType ||
            "",

          headerText:
            day.compositionHeader ||
            composedDay.headerText ||
            "",

          timelineRows:
            Array.isArray(
              day.timeline
            )
              ? day.timeline.length
              : (
                Array.isArray(
                  composedDay.timeline
                )
                  ? composedDay
                      .timeline
                      .length
                  : 0
              ),

          notes:
            Array.isArray(
              day.renderNotes
            )
              ? day.renderNotes.length
              : (
                Array.isArray(
                  composedDay.notes
                )
                  ? composedDay
                      .notes
                      .length
                  : 0
              ),

          hasNewActorContent:
            Boolean(
              day.rendering &&
              day.rendering
                .hasNewActorContent
            ),

          guestSpellerExposed:
            performances.some(
              function (
                performance
              ) {
                return (
                  performance
                    .guestSpeller !==
                  undefined
                );
              }
            ),

          putIns:
            putIns.map(
              function (putIn) {
                return {
                  title:
                    putIn.title,

                  assignments:
                    Array.isArray(
                      putIn.assignments
                    )
                      ? putIn
                          .assignments
                          .length
                      : 0,

                  newActors:
                    Array.isArray(
                      putIn.newActors
                    )
                      ? putIn
                          .newActors
                          .length
                      : 0,

                  hasNewActors:
                    Boolean(
                      putIn.hasNewActors
                    )
                };
              }
            )
        };
      }
    );

  const guestSpellerExposed =
    dayResults.some(
      function (day) {
        return day
          .guestSpellerExposed;
      }
    );

  const missingTemplateTypes =
    dayResults.filter(
      function (day) {
        return !day.templateType;
      }
    );

  const result = {
    test:
      "WeeklyOS Template Engine",

    weekStart:
      composed.weekStart,

    weekEnd:
      composed.weekEnd,

    requiredFunctions:
      requiredFunctions,

    compositionVersion:
      composed.composition
        ? composed.composition.version
        : "",

    days:
      dayResults,

    compositionSummary:
      typeof weeklyOSBuildCompositionSummary_ ===
        "function"
        ? weeklyOSBuildCompositionSummary_(
            composed
          )
        : null,

    checks: {
      sevenDays:
        composed.days.length === 7,

      allDaysComposed:
        composedDays.length === 7,

      allDaysHaveTemplateType:
        missingTemplateTypes.length === 0,

      guestSpellerPrivacy:
        !guestSpellerExposed,

      putInAssignmentsBuilt:
        composed.days.every(
          function (day) {
            return (
              !day.putIns.length ||
              day.putIns.every(
                function (putIn) {
                  return (
                    Array.isArray(
                      putIn.assignments
                    ) &&
                    putIn.assignments
                      .length > 0
                  );
                }
              )
            );
          }
        )
    }
  };

  result.passed =
    result.checks.sevenDays &&
    result.checks.allDaysComposed &&
    result.checks
      .allDaysHaveTemplateType &&
    result.checks
      .guestSpellerPrivacy &&
    result.checks
      .putInAssignmentsBuilt;

  weeklyOSTestLog_(
    result
  );

  return result;
}

/*************************************************
 * WEEKLYOS EMERGENCY REVIEW GENERATOR
 *
 * Temporary review output while the final WeeklyOS
 * template generator is being completed.
 *
 * Creates a readable sheet from the current saved
 * WeeklyOS draft.
 *************************************************/

function weeklyOSGenerateEmergencyReview() {
  const ss =
    SpreadsheetApp.getActiveSpreadsheet();

  const draft =
    weeklyOSGetDraft();

  if (!draft) {
    throw new Error(
      "WeeklyOS could not find a saved draft."
    );
  }

  /*
   * Use the existing Composer when available.
   * It already turns each day into timeline rows
   * and review notes.
   */
  const output =
    typeof weeklyOSComposeDraft_ === "function"
      ? weeklyOSComposeDraft_(draft)
      : weeklyOSDeepClone_(draft);

  const weekStart =
    weeklyOSFormatDate_(
      draft.weekStart,
      "M.d.yy"
    );

  const weekEnd =
    weeklyOSFormatDate_(
      draft.weekEnd,
      "M.d.yy"
    );

  const sheetName =
    "WeeklyOS REVIEW " +
    weekStart +
    " - " +
    weekEnd;

  const existing =
    ss.getSheetByName(sheetName);

  if (existing) {
    ss.deleteSheet(existing);
  }

  const sheet =
    ss.insertSheet(sheetName);

  const rows = [];

  rows.push([
    "THE 25TH ANNUAL PUTNAM COUNTY SPELLING BEE",
    "",
    "",
    ""
  ]);

  rows.push([
    "WEEKLY SCHEDULE REVIEW",
    weekStart + " – " + weekEnd,
    "",
    ""
  ]);

  rows.push([
    "",
    "",
    "",
    ""
  ]);

  const days =
    Array.isArray(output.days)
      ? output.days
      : [];

  days.forEach(function (day) {
    const dateLabel =
      day.dateLabel ||
      weeklyOSFormatDate_(
        day.date,
        "EEEE, MMMM d"
      );

    const headline =
      day.compositionHeader ||
      buildEmergencyWeeklyHeadline_(day);

    rows.push([
      dateLabel,
      headline,
      "",
      ""
    ]);

    const timeline =
      Array.isArray(day.timeline)
        ? day.timeline
        : [];

    if (timeline.length) {
      timeline.forEach(function (item) {
        rows.push([
          "",
          item.time || "",
          item.activity || "",
          item.called || ""
        ]);
      });
    } else {
      buildEmergencyTimelineRows_(
        day
      ).forEach(function (item) {
        rows.push([
          "",
          item.time || "",
          item.activity || "",
          item.called || ""
        ]);
      });
    }

    const notes =
      Array.isArray(day.renderNotes)
        ? day.renderNotes
        : buildEmergencyNotes_(day);

    if (notes.length) {
      rows.push([
        "",
        "NOTES",
        "",
        ""
      ]);

      notes.forEach(function (note) {
        rows.push([
          "",
          "",
          typeof note === "string"
            ? note
            : (
              note.text ||
              note.activity ||
              ""
            ),
          ""
        ]);
      });
    }

    rows.push([
      "",
      "",
      "",
      ""
    ]);
  });

  sheet
    .getRange(
      1,
      1,
      rows.length,
      4
    )
    .setValues(rows);

  /*
   * General formatting.
   */
  sheet
    .getDataRange()
    .setFontFamily("Arial")
    .setFontSize(10)
    .setVerticalAlignment("top")
    .setWrap(true);

  sheet.setColumnWidth(1, 175);
  sheet.setColumnWidth(2, 125);
  sheet.setColumnWidth(3, 520);
  sheet.setColumnWidth(4, 260);

  sheet.setFrozenRows(2);

  /*
   * Top title rows.
   */
  sheet
    .getRange("A1:D1")
    .merge()
    .setFontSize(15)
    .setFontWeight("bold")
    .setHorizontalAlignment("center");

  sheet
    .getRange("A2:D2")
    .setFontWeight("bold");

  /*
   * Format each date/header and notes row.
   */
  for (
    let row = 4;
    row <= sheet.getLastRow();
    row++
  ) {
    const colA =
      String(
        sheet
          .getRange(row, 1)
          .getDisplayValue() || ""
      ).trim();

    const colB =
      String(
        sheet
          .getRange(row, 2)
          .getDisplayValue() || ""
      ).trim();

    if (colA) {
      sheet
        .getRange(row, 1, 1, 4)
        .setFontWeight("bold")
        .setBackground("#f7f0d8")
        .setBorder(
          true,
          true,
          true,
          true,
          false,
          false
        );
    }

    if (colB === "NOTES") {
      sheet
        .getRange(row, 1, 1, 4)
        .setFontWeight("bold")
        .setBackground("#eeeeee");
    }
  }

  sheet.activate();

  SpreadsheetApp.flush();

  SpreadsheetApp
    .getUi()
    .alert(
      "WeeklyOS Review Created",
      'Created "' +
        sheetName +
        '".\n\n' +
        "This is a temporary review tab for your boss. " +
        "It does not replace the final Weekly Schedule generator.",
      SpreadsheetApp
        .getUi()
        .ButtonSet.OK
    );

  return {
    ok: true,
    sheetName: sheetName,
    sheetId: sheet.getSheetId()
  };
}


/*************************************************
 * EMERGENCY HEADLINE FALLBACK
 *************************************************/

function buildEmergencyWeeklyHeadline_(day) {
  if (day.dayOff) {
    return (
      day.dayOff.title ||
      "AEA DAY OFF"
    );
  }

  const parts = [];

  (day.rehearsals || []).forEach(function (item) {
    if (item.canceled) return;

    parts.push(
      [
        item.title || "Rehearsal",
        [
          item.startTime,
          item.endTime
        ]
          .filter(Boolean)
          .join("–")
      ]
        .filter(Boolean)
        .join(" — ")
    );
  });

  (day.meetings || []).forEach(function (item) {
    parts.push(
      [
        item.title || "Meeting",
        [
          item.startTime,
          item.endTime
        ]
          .filter(Boolean)
          .join("–")
      ]
        .filter(Boolean)
        .join(" — ")
    );
  });

  (day.workCalls || []).forEach(function (item) {
    parts.push(
      [
        item.title || "Work Call",
        [
          item.startTime,
          item.endTime
        ]
          .filter(Boolean)
          .join("–")
      ]
        .filter(Boolean)
        .join(" — ")
    );
  });

  (day.putIns || []).forEach(function (item) {
    parts.push(
      [
        item.title || "Put-In",
        [
          item.startTime,
          item.endTime
        ]
          .filter(Boolean)
          .join("–")
      ]
        .filter(Boolean)
        .join(" — ")
    );
  });

  (day.performances || []).forEach(function (item) {
    parts.push(
      [
        item.performanceNumber
          ? "PERFORMANCE #" +
            item.performanceNumber
          : (
            item.label ||
            "PERFORMANCE"
          ),
        item.time
      ]
        .filter(Boolean)
        .join(" — ")
    );
  });

  return parts.join(" + ");
}


/*************************************************
 * EMERGENCY TIMELINE FALLBACK
 *************************************************/

function buildEmergencyTimelineRows_(day) {
  const rows = [];

  if (day.dayOff) {
    rows.push({
      time: "",
      activity:
        day.dayOff.title ||
        "AEA DAY OFF",
      called: ""
    });

    return rows;
  }

  (day.rehearsals || []).forEach(function (item) {
    if (item.canceled) return;

    rows.push({
      time:
        [
          item.startTime,
          item.endTime
        ]
          .filter(Boolean)
          .join("–"),

      activity:
        item.title ||
        "Rehearsal",

      called:
        (item.called || [])
          .join(", ")
    });
  });

  (day.meetings || []).forEach(function (item) {
    rows.push({
      time:
        [
          item.startTime,
          item.endTime
        ]
          .filter(Boolean)
          .join("–"),

      activity:
        item.title ||
        "Meeting",

      called:
        (item.called || [])
          .join(", ")
    });
  });

  (day.workCalls || []).forEach(function (item) {
    rows.push({
      time:
        [
          item.startTime,
          item.endTime
        ]
          .filter(Boolean)
          .join("–"),

      activity:
        item.title ||
        "Work Call",

      called:
        (item.called || [])
          .join(", ")
    });
  });

  (day.performances || []).forEach(function (performance) {
    const lines = [];

    lines.push(
      performance.performanceNumber
        ? "PERFORMANCE #" +
          performance.performanceNumber
        : (
          performance.label ||
          "PERFORMANCE"
        )
    );

    if (performance.conductor) {
      lines.push(
        "Conductor = " +
        performance.conductor
      );
    }

    (day.castOuts || []).forEach(function (outItem) {
      if (
        typeof weeklyOSOutAppliesToPerformance_ ===
          "function" &&
        !weeklyOSOutAppliesToPerformance_(
          outItem,
          performance
        )
      ) {
        return;
      }

      let line =
        (outItem.person || "Cast member") +
        " OUT";

      if (outItem.role) {
        line +=
          ", " +
          outItem.role;
      }

      if (outItem.coverage) {
        line +=
          " = " +
          outItem.coverage;
      }

      lines.push(line);
    });

    rows.push({
      time:
        performance.time ||
        "",

      activity:
        lines.join("\n"),

      called: ""
    });
  });

  return rows;
}


/*************************************************
 * EMERGENCY NOTES FALLBACK
 *************************************************/

function buildEmergencyNotes_(day) {
  const notes = [];

  (day.crewOuts || []).forEach(function (item) {
    let text =
      "- " +
      (item.person || "Crew member") +
      " OUT";

    if (item.coverage) {
      text +=
        ", " +
        item.coverage +
        " IN";
    }

    if (item.department) {
      text +=
        " (" +
        item.department +
        ")";
    }

    notes.push(text);
  });

  (day.pt || []).forEach(function (item) {
    let text =
      "- PT";

    const time =
      [
        item.startTime,
        item.endTime
      ]
        .filter(Boolean)
        .join("–");

    if (time) {
      text += " " + time;
    }

    if (item.location) {
      text +=
        " (" +
        item.location +
        ")";
    }

    notes.push(text);
  });

  (day.notes || []).forEach(function (item) {
    const text =
      typeof item === "string"
        ? item
        : item.text;

    if (text) {
      notes.push(text);
    }
  });

  return notes;
}

/*************************************************
 * PROMOTE WEEKLYOS REVIEW TO REAL WEEKLY TAB
 *
 * Fast production bridge:
 * - Finds the current WeeklyOS REVIEW tab
 * - Copies it
 * - Gives it the standard Weekly Schedule name
 * - Places it beside Weekly Template
 * - Sets B3 to the correct Monday
 *
 * The review tab remains as a backup.
 *************************************************/

function weeklyOSPromoteReviewToWeeklySchedule() {
  const ss =
    SpreadsheetApp.getActiveSpreadsheet();

  const ui =
    SpreadsheetApp.getUi();

  const draft =
    weeklyOSGetDraft();

  if (!draft) {
    throw new Error(
      "WeeklyOS could not find the saved weekly draft."
    );
  }

  const monday =
    weeklyOSAsDate_(
      draft.weekStart
    );

  const sunday =
    weeklyOSAsDate_(
      draft.weekEnd
    );

  if (!monday || !sunday) {
    throw new Error(
      "WeeklyOS could not determine the week dates."
    );
  }

  const tz =
    Session.getScriptTimeZone();

  const reviewSheetName =
    "WeeklyOS REVIEW " +
    Utilities.formatDate(
      monday,
      tz,
      "M.d.yy"
    ) +
    " - " +
    Utilities.formatDate(
      sunday,
      tz,
      "M.d.yy"
    );

  const finalSheetName =
    "Weekly Schedule Mon " +
    Utilities.formatDate(
      monday,
      tz,
      "M.d.yy"
    ) +
    " - Sun " +
    Utilities.formatDate(
      sunday,
      tz,
      "M.d.yy"
    );

  const reviewSheet =
    ss.getSheetByName(
      reviewSheetName
    );

  if (!reviewSheet) {
    throw new Error(
      'Could not find "' +
      reviewSheetName +
      '". Run the WeeklyOS generator first.'
    );
  }

  const existingFinal =
    ss.getSheetByName(
      finalSheetName
    );

  if (existingFinal) {
    const response =
      ui.alert(
        "Replace Existing Weekly Schedule?",
        '"' +
          finalSheetName +
          '" already exists.\n\n' +
          "Replace it with the current WeeklyOS review output?",
        ui.ButtonSet.YES_NO
      );

    if (
      response !==
      ui.Button.YES
    ) {
      return {
        ok: false,
        canceled: true
      };
    }

    ss.deleteSheet(
      existingFinal
    );
  }

  /*
   * Copy the working review output so the review tab
   * remains available as a backup.
   */
  const finalSheet =
    reviewSheet
      .copyTo(ss)
      .setName(
        finalSheetName
      );

  /*
   * Keep the standard Monday anchor available for
   * Prep, Weekly Cache, and other StageOS workflows.
   */
  finalSheet
    .getRange("B3")
    .setValue(monday)
    .setNumberFormat(
      "mmmm d, yyyy"
    );

  /*
   * Move the real Weekly Schedule beside the template.
   */
  const template =
    ss.getSheetByName(
      "Weekly Template"
    );

  ss.setActiveSheet(
    finalSheet
  );

  if (template) {
    ss.moveActiveSheet(
      template.getIndex() + 1
    );
  }

  /*
   * Record the generated sheet on the draft.
   */
  draft.status =
    "GENERATED";

  draft.metadata =
    draft.metadata || {};

  draft.metadata.generatedSheetId =
    finalSheet.getSheetId();

  draft.metadata.generatedSheetName =
    finalSheetName;

  draft.metadata.generatedAt =
    new Date().toISOString();

  weeklyOSSaveDraft(
    draft
  );

  /*
   * Clear any old Weekly cache so Prep reads this
   * newly generated schedule.
   */
  if (
    typeof WeeklyCacheOS ===
    "function"
  ) {
    try {
      WeeklyCacheOS().clear();
    } catch (error) {
      console.log(
        "Weekly cache clear skipped: " +
        error.message
      );
    }
  }

  SpreadsheetApp.flush();

  ui.alert(
    "Weekly Schedule Created",
    'Created "' +
      finalSheetName +
      '".\n\n' +
      "This is now the active tab for next week.",
    ui.ButtonSet.OK
  );

  return {
    ok: true,
    sheetName:
      finalSheetName,
    sheetId:
      finalSheet.getSheetId()
  };
}



/*************************************************
 * SAVE DRAFT
 *
 * Used by popup autosave.
 *
 * Autosave does not increment the revision.
 * A source refresh, restore, or generation step
 * controls revision changes separately.
 *
 * Public endpoint for google.script.run.
 *************************************************/

function weeklyOSUiSaveDraft(
  incomingDraft
) {
  const draft =
    weeklyOSPrepareIncomingDraft_(
      incomingDraft
    );

  draft.status =
    draft.status === "GENERATED"
      ? "GENERATED"
      : "IN_PROGRESS";

  weeklyOSRecalculateDraft_(
    draft
  );

  weeklyOSSaveDraft(
    draft
  );

  return {
    draft:
      draft,

    validation:
      draft.validation,

    savedAt:
      draft.updatedAt,

    message:
      "Draft saved."
  };
}


/*************************************************
 * VALIDATE UNSAVED UI DRAFT
 *
 * Lets the popup refresh its warnings without
 * first requiring a save.
 *
 * Public endpoint for google.script.run.
 *************************************************/

function weeklyOSUiValidateDraft(
  incomingDraft
) {
  const draft =
    weeklyOSPrepareIncomingDraft_(
      incomingDraft
    );

  weeklyOSRecalculateDraft_(
    draft
  );

  return {
    validation:
      draft.validation,

    days:
      draft.days.map(
        function (day) {
          return {
            date:
              day.date,

            status:
              day.status,

            statusLabels:
              day.statusLabels,

            confidence:
              day.confidence,

            observations:
              day.observations
          };
        }
      ),

    observations:
      draft.observations
  };
}


/*************************************************
 * GENERATE WEEKLY SCHEDULE
 *
 * Saves the popup draft immediately before
 * generation so the sheet always reflects the
 * latest reviewed data.
 *
 * Public endpoint for google.script.run.
 *************************************************/

function weeklyOSUiGenerate(
  incomingDraft
) {
  const draft =
    weeklyOSPrepareIncomingDraft_(
      incomingDraft
    );

  weeklyOSRecalculateDraft_(
    draft
  );

  weeklyOSSaveDraft(
    draft
  );

  const result =
    weeklyOSGenerateFromDraft_(
      draft
    );

  const savedDraft =
    weeklyOSGetDraft(
      draft.weekStart
    ) || draft;

  return {
    ok:
      true,

    message:
      result &&
      result.message
        ? result.message
        : "Weekly Schedule generated.",

    sheetName:
      result &&
      result.sheetName
        ? result.sheetName
        : (
          savedDraft.metadata &&
          savedDraft.metadata
            .generatedSheetName
            ? savedDraft.metadata
                .generatedSheetName
            : ""
        ),

    sheetId:
      result &&
      result.sheetId
        ? result.sheetId
        : (
          savedDraft.metadata &&
          savedDraft.metadata
            .generatedSheetId
            ? savedDraft.metadata
                .generatedSheetId
            : null
        ),

    draft:
      savedDraft
  };
}



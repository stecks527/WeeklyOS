/*************************************************
 * BACKFILL CREW COVERAGE FROM CREW OUTS
 *
 * Crew Outs stores the existing cover in column H.
 * WeeklyOS crew-out objects already retain their
 * source row, so this safely enriches the record
 * without re-parsing the entire sheet layout.
 *************************************************/

function weeklyOSBackfillCrewCoverageFromSheet_(
  draft
) {
  if (
    !draft ||
    !Array.isArray(
      draft.days
    )
  ) {
    return draft;
  }

  const config =
    weeklyOSGetConfig_();

  const sheet =
    weeklyOSGetSheetSafe_(
      config.sheets.crewOuts
    );

  if (!sheet) {
    return draft;
  }

  const lastRow =
    sheet.getLastRow();

  if (lastRow < 1) {
    return draft;
  }

  const coverageValues =
    sheet
      .getRange(
        1,
        8,
        lastRow,
        1
      )
      .getDisplayValues();

  draft.days.forEach(
    function (day) {
      (
        day.crewOuts || []
      ).forEach(
        function (outItem) {
          if (outItem.coverage) {
            return;
          }

          const sourceRows =
            Array.isArray(
              outItem.sourceRows
            )
              ? outItem.sourceRows
              : [];

          for (
            let index = 0;
            index <
              sourceRows.length;
            index++
          ) {
            const rowNumber =
              Number(
                sourceRows[index]
              );

            if (
              !rowNumber ||
              rowNumber < 1 ||
              rowNumber >
                coverageValues.length
            ) {
              continue;
            }

            const coverage =
              weeklyOSNormalizeText_(
                coverageValues[
                  rowNumber - 1
                ][0]
              );

            if (!coverage) {
              continue;
            }

            outItem.coverage =
              coverage;

            outItem.requiresReview =
              false;

            break;
          }
        }
      );
    }
  );

  return draft;
}


/*************************************************
 * SAFE JSON FOR HTML TEMPLATE
 *
 * Protects against a JSON value accidentally
 * ending the script tag inside the HTML file.
 *************************************************/

function weeklyOSSafeJsonForHtml_(
  value
) {
  return JSON.stringify(
    value
  )
    .replace(
      /</g,
      "\\u003c"
    )
    .replace(
      />/g,
      "\\u003e"
    )
    .replace(
      /&/g,
      "\\u0026"
    )
    .replace(
      /\u2028/g,
      "\\u2028"
    )
    .replace(
      /\u2029/g,
      "\\u2029"
    );
}



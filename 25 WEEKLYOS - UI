/*************************************************
 * UI PEOPLE OPTIONS
 *
 * Provides a searchable list of company members
 * for coverage fields.
 *
 * Role-specific coverage filtering will come from
 * ResolverOS later. For now, this keeps entry fast
 * while still allowing a manually entered name.
 *************************************************/

function weeklyOSGetUiPeopleOptions_() {
  const config =
    weeklyOSGetConfig_();

  const sheet =
    weeklyOSGetSheetSafe_(
      config.sheets.contactSheet
    );

  if (!sheet) {
    return [];
  }

  const values =
    sheet
      .getDataRange()
      .getDisplayValues();

  const header =
    weeklyOSFindContactSheetHeaders_(
      values
    );

  const people = [];

  for (
    let rowIndex =
      header.headerRow + 1;
    rowIndex < values.length;
    rowIndex++
  ) {
    const name =
      weeklyOSNormalizeText_(
        values[rowIndex][
          header.nameColumn
        ]
      );

    if (!name) {
      continue;
    }

    people.push(name);
  }

  return weeklyOSUniqueStrings_(
    people
  ).sort(
    function (first, second) {
      return first.localeCompare(
        second
      );
    }
  );
}

/*************************************************
 * UI SWING OPTIONS
 *
 * Reads Contact Sheet titles/departments and
 * returns every performer identified as a Swing.
 *************************************************/

function weeklyOSGetUiSwingOptions_() {
  const config = weeklyOSGetConfig_();
  const sheet = weeklyOSGetSheetSafe_(
    config.sheets.contactSheet
  );

  if (!sheet) return [];

  const values = sheet.getDataRange().getDisplayValues();
  const header = weeklyOSFindContactSheetHeaders_(values);
  const swings = [];

  for (
    let rowIndex = header.headerRow + 1;
    rowIndex < values.length;
    rowIndex++
  ) {
    const row = values[rowIndex];
    const name = weeklyOSNormalizeText_(
      row[header.nameColumn]
    );

    if (!name) continue;

    const title = header.titleColumn >= 0
      ? weeklyOSNormalizeText_(row[header.titleColumn])
      : "";

    const department = header.departmentColumn >= 0
      ? weeklyOSNormalizeText_(row[header.departmentColumn])
      : "";

    const combined = weeklyOSUpper_(
      title + " " + department
    );

    if (combined.indexOf("SWING") >= 0) {
      swings.push(name);
    }
  }

  return weeklyOSUniqueStrings_(swings).sort(
    function (first, second) {
      return first.localeCompare(second);
    }
  );
}


/*************************************************
 * UI KNOWN NEW-ACTOR OPTIONS
 *
 * Supplies role-to-actor information already
 * present in the WeekModel. This intentionally
 * does not guess when WeeklyOS lacks a clear role
 * mapping.
 *************************************************/

function weeklyOSGetUiNewActorOptions_(draft) {
  const options = [];

  if (!draft || !Array.isArray(draft.days)) {
    return options;
  }

  draft.days.forEach(function (day) {
    (day.putIns || []).forEach(function (putIn) {
      (putIn.newActors || []).forEach(function (item) {
        weeklyOSPushUiNewActorOption_(options, item);
      });

      (putIn.assignments || []).forEach(function (assignment) {
        if (assignment.isNewActor) {
          weeklyOSPushUiNewActorOption_(options, {
            role: assignment.role,
            person: assignment.person,
            source: assignment.source || "Put-In"
          });
        }
      });
    });

    (day.companyEvents || []).forEach(function (event) {
      if (event.role && event.person) {
        weeklyOSPushUiNewActorOption_(options, {
          role: event.role,
          person: event.person,
          source: event.source || "Company Activity"
        });
      }

      (event.assignments || []).forEach(function (assignment) {
        weeklyOSPushUiNewActorOption_(options, assignment);
      });
    });
  });

  return weeklyOSDeduplicateByKey_(
    options,
    function (item) {
      return weeklyOSUpper_(item.role) + "|" +
        weeklyOSUpper_(item.person);
    }
  );
}


function weeklyOSPushUiNewActorOption_(options, item) {
  item = item || {};

  const role = weeklyOSNormalizeText_(
    item.role || item.character || item.track
  );

  const person = weeklyOSNormalizeText_(
    item.person || item.name || item.actor
  );

  if (!role || !person) return;

  options.push({
    role: role,
    person: person,
    source: item.source || "WeeklyOS"
  });
}

/*************************************************
 * GET SHOW TITLE
 *
 * User-facing WeeklyOS branding comes from the
 * production settings already used by StageOS.
 *
 * Resolution order:
 * 1. getShowOSSettings()
 * 2. getStageOSSettings()
 * 3. Production Settings label/value pairs
 * 4. Spreadsheet name
 *************************************************/

function weeklyOSGetShowTitle_() {
  const settingsFunctions = [
    "getShowOSSettings",
    "getStageOSSettings"
  ];

  for (
    let index = 0;
    index < settingsFunctions.length;
    index++
  ) {
    const functionName =
      settingsFunctions[index];

    if (
      typeof this[functionName] !==
      "function"
    ) {
      continue;
    }

    try {
      const settings =
        this[functionName]();

      const fromSettings =
        weeklyOSExtractShowTitleFromSettings_(
          settings
        );

      if (fromSettings) {
        return fromSettings;
      }
    } catch (error) {
      weeklyOSLog_(
        "Could not read show title from " +
          functionName +
          ".",
        {
          message:
            error.message
        }
      );
    }
  }

  const fromSheet =
    weeklyOSReadShowTitleFromProductionSettings_();

  if (fromSheet) {
    return fromSheet;
  }

  const spreadsheetName =
    weeklyOSNormalizeText_(
      weeklyOSGetSpreadsheet_()
        .getName()
    );

  if (spreadsheetName) {
    return spreadsheetName
      .replace(
        /\s*[–—-]\s*(STAGEOS|SMOS).*$/i,
        ""
      )
      .trim() ||
      spreadsheetName;
  }

  return "StageOS";
}


function weeklyOSExtractShowTitleFromSettings_(
  settings
) {
  if (!settings) {
    return "";
  }

  const keys = [
    "showTitle",
    "showName",
    "productionTitle",
    "productionName",
    "title",
    "show"
  ];

  for (
    let index = 0;
    index < keys.length;
    index++
  ) {
    const value =
      weeklyOSNormalizeText_(
        settings[keys[index]]
      );

    if (value) {
      return value;
    }
  }

  if (
    settings.production &&
    typeof settings.production ===
      "object"
  ) {
    return weeklyOSExtractShowTitleFromSettings_(
      settings.production
    );
  }

  return "";
}


function weeklyOSReadShowTitleFromProductionSettings_() {
  const sheet =
    weeklyOSGetSheetSafe_(
      "Production Settings"
    );

  if (!sheet) {
    return "";
  }

  const values =
    sheet
      .getDataRange()
      .getDisplayValues();

  const acceptedLabels = {
    "SHOW TITLE": true,
    "SHOW NAME": true,
    "PRODUCTION TITLE": true,
    "PRODUCTION NAME": true
  };

  for (
    let rowIndex = 0;
    rowIndex < values.length;
    rowIndex++
  ) {
    const row =
      values[rowIndex];

    for (
      let columnIndex = 0;
      columnIndex < row.length - 1;
      columnIndex++
    ) {
      const label =
        weeklyOSUpper_(
          row[columnIndex]
        );

      if (!acceptedLabels[label]) {
        continue;
      }

      const value =
        weeklyOSNormalizeText_(
          row[columnIndex + 1]
        );

      if (value) {
        return value;
      }
    }
  }

  return "";
}


/*************************************************
 * GET CURRENT DRAFT
 *
 * Public endpoint for google.script.run.
 *************************************************/

function weeklyOSUiGetDraft() {
  const draft =
    weeklyOSGetDraft();

  if (!draft) {
    return null;
  }

  weeklyOSUpgradeDraftModel_(
    draft
  );

  weeklyOSRecalculateDraft_(
    draft
  );

  return draft;
}


/*************************************************
 * GET UI BOOTSTRAP
 *
 * Public endpoint for google.script.run.
 *************************************************/

function weeklyOSUiGetBootstrap() {
  const draft =
    weeklyOSGetDraft();

  if (!draft) {
    return {
      version:
        weeklyOSGetConfig_()
          .version,

      savedDrafts:
        weeklyOSListSavedDrafts_(),

      draftHistory: []
    };
  }

  return weeklyOSBuildUiBootstrap_(
    draft
  );
}


/*************************************************
 * BUILD DRAFT FOR SELECTED WEEK
 *
 * Public endpoint for google.script.run.
 *************************************************/

function weeklyOSUiBuildDraft(
  weekStart
) {
  const monday =
    weeklyOSFindMonday_(
      weekStart
    );

  const existing =
    weeklyOSGetDraft(
      monday
    );

  if (existing) {
    weeklyOSSetCurrentDraftWeek_(
      monday
    );

    weeklyOSUpgradeDraftModel_(
      existing
    );

    weeklyOSRecalculateDraft_(
      existing
    );

    return {
      draft:
        existing,

      bootstrap:
        weeklyOSBuildUiBootstrap_(
          existing
        ),

      resumed:
        true
    };
  }

  const draft =
    weeklyOSBuildDraft(
      monday
    );

  return {
    draft:
      draft,

    bootstrap:
      weeklyOSBuildUiBootstrap_(
        draft
      ),

    resumed:
      false
  };
}


/*************************************************
 * LOAD SAVED DRAFT FOR WEEK

/*************************************************
 * OPEN WEEKLYOS BUILDER
 *
 * Always refreshes the saved draft from current
 * source sheets before opening.
 *
 * weeklyOSRefreshDraft() preserves:
 * - manual rehearsals
 * - manual meetings
 * - manual work calls
 * - manual put-ins
 * - manual notes
 * - coverage choices
 * - review status
 *************************************************/

function weeklyOSOpenBuilder() {
  let draft =
    weeklyOSGetDraft();

  if (!draft) {
    /*
     * No saved draft exists, so build the next week
     * from all current source sheets.
     */
    draft =
      weeklyOSBuildDraft(
        weeklyOSNextMonday_()
      );
  } else {
    /*
     * A saved draft exists.
     *
     * Refresh it before opening so new information
     * from Expanded Calendar—including conductors—
     * appears without requiring the user to clear
     * and rebuild the draft.
     */
    draft =
      weeklyOSRefreshDraft();
  }

  weeklyOSBackfillCrewCoverageFromSheet_(
    draft
  );

  weeklyOSRecalculateDraft_(
    draft
  );

  weeklyOSSaveDraft(
    draft
  );

  return weeklyOSShowBuilderDialog_(
    draft
  );
}

/*************************************************
 * OPEN BUILDER FOR A SPECIFIC WEEK
 *
 * Useful later for:
 *
 * - Build another week
 * - Resume an older draft
 * - Open a week from HomeOS
 *************************************************/

/*************************************************
 * OPEN BUILDER FOR A SPECIFIC WEEK
 *
 * Existing drafts are refreshed from current sources
 * before opening, while preserving manual edits.
 *************************************************/

function weeklyOSOpenBuilderForWeek(
  weekStart
) {
  const monday =
    weeklyOSFindMonday_(
      weekStart
    );

  let draft =
    weeklyOSGetDraft(
      monday
    );

  if (!draft) {
    /*
     * No saved draft exists for this week.
     */
    draft =
      weeklyOSBuildDraft(
        monday
      );

  } else {
    /*
     * Make this the active draft first so
     * weeklyOSRefreshDraft() refreshes the correct week.
     *
     * Manual rehearsals, meetings, work calls, put-ins,
     * notes, coverage choices, and review status survive
     * the refresh through the existing merge process.
     */
    weeklyOSSetCurrentDraftWeek_(
      monday
    );

    draft =
      weeklyOSRefreshDraft();
  }

  weeklyOSBackfillCrewCoverageFromSheet_(
    draft
  );

  weeklyOSRecalculateDraft_(
    draft
  );

  weeklyOSSaveDraft(
    draft
  );

  return weeklyOSShowBuilderDialog_(
    draft
  );
}

/*************************************************
 * SHOW BUILDER DIALOG
 *************************************************/

function weeklyOSShowBuilderDialog_(
  draft
) {
  if (!draft) {
    throw new Error(
      "WeeklyOS could not open because no draft was available."
    );
  }

  weeklyOSUpgradeDraftModel_(
    draft
  );

  weeklyOSBackfillCrewCoverageFromSheet_(
    draft
  );

  weeklyOSRecalculateDraft_(
    draft
  );

  const showTitle =
    weeklyOSGetShowTitle_();

  const template =
    HtmlService.createTemplateFromFile(
      "WeeklyOS Builder"
    );

  template.initialDraftJson =
    weeklyOSSafeJsonForHtml_(
      draft
    );

  template.initialBootstrapJson =
    weeklyOSSafeJsonForHtml_(
      weeklyOSBuildUiBootstrap_(
        draft
      )
    );

  const html =
    template
      .evaluate()
      .setWidth(1180)
      .setHeight(760);

  SpreadsheetApp
    .getUi()
    .showModalDialog(
      html,
      showTitle +
        " — Weekly Schedule Builder"
    );

  return true;
}



/*************************************************
 * MARK DAY REVIEWED
 *
 * Optional lightweight endpoint for future UI
 * versions that save one day at a time.
 *
 * Public endpoint for google.script.run.
 *************************************************/

function weeklyOSUiSetDayReviewed(
  dateValue,
  reviewed
) {
  const draft =
    weeklyOSGetDraft();

  if (!draft) {
    throw new Error(
      "WeeklyOS could not find a current draft."
    );
  }

  const day =
    weeklyOSGetDay_(
      draft,
      dateValue
    );

  if (!day) {
    throw new Error(
      "WeeklyOS could not find that day in the current draft."
    );
  }

  day.reviewed =
    Boolean(reviewed);

  weeklyOSRecalculateDraft_(
    draft
  );

  weeklyOSSaveDraft(
    draft
  );

  return {
    day:
      day,

    validation:
      draft.validation,

    savedAt:
      draft.updatedAt
  };
}


/*************************************************
 * PREPARE DRAFT RECEIVED FROM HTML
 *
 * Browser data is plain JSON. This function
 * restores missing WeekModel fields and protects
 * server-owned metadata.
 *************************************************/

function weeklyOSPrepareIncomingDraft_(
  incomingDraft
) {
  if (!incomingDraft) {
    throw new Error(
      "WeeklyOS did not receive a draft from the popup."
    );
  }

  const draft =
    weeklyOSDeepClone_(
      incomingDraft
    );

  if (!draft.id) {
    throw new Error(
      "WeeklyOS received a draft without an ID."
    );
  }

  if (!draft.weekStart) {
    throw new Error(
      "WeeklyOS received a draft without a week-start date."
    );
  }

  const savedDraft =
    weeklyOSGetDraft(
      draft.weekStart
    );

  weeklyOSUpgradeDraftModel_(
    draft
  );

  draft.weekStart =
    weeklyOSDateKey_(
      weeklyOSFindMonday_(
        draft.weekStart
      )
    );

  draft.weekEnd =
    weeklyOSDateKey_(
      weeklyOSAddDays_(
        draft.weekStart,
        6
      )
    );

  if (savedDraft) {
    draft.createdAt =
      savedDraft.createdAt ||
      draft.createdAt;

    draft.revision =
      Number(
        savedDraft.revision ||
        draft.revision ||
        1
      );

    draft.metadata =
      Object.assign(
        {},
        savedDraft.metadata || {},
        draft.metadata || {}
      );
  }

  draft.createdAt =
    draft.createdAt ||
    weeklyOSNowIso_();

  draft.updatedAt =
    weeklyOSNowIso_();

  return draft;
}



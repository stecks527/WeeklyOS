  const draft =
    weeklyOSGetDraft();

  if (!draft) {
    ui.alert(
      "WeeklyOS",
      "No saved WeeklyOS draft was found.",
      ui.ButtonSet.OK
    );

    return;
  }

  const result =
    weeklyOSValidateDraft(
      draft
    );

  const messages = [];

  if (
    Array.isArray(
      result.errors
    )
  ) {
    result.errors.forEach(
      function (item) {
        messages.push(
          "• " +
          item.message
        );
      }
    );
  }

  if (
    Array.isArray(
      result.warnings
    )
  ) {
    result.warnings.forEach(
      function (item) {
        messages.push(
          "⚠ " +
          item.message
        );
      }
    );
  }

  const message =
    result.isValid
      ? (
        messages.length
          ? "Draft is valid, with warnings:\n\n" +
            messages.join("\n")
          : "Draft is ready to generate."
      )
      : (
        messages.length
          ? messages.join("\n")
          : "The draft is not ready to generate."
      );

  ui.alert(
    "WeeklyOS Validation",
    message,
    ui.ButtonSet.OK
  );
}


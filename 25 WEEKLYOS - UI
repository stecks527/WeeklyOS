/*************************************************
 * UI CAST COVERAGE BY ROLE
 *
 * Canonical source: Cast List
 *
 * Cast List:
 * B = Full Name
 * D = Full Character
 * E = Role
 * F = Covers
 *
 * Returns the same eligible actors under both the
 * short role and full-character keys.
 *
 * Temporary company-change rule:
 * Fernell Hogan covers Leaf / Leaf Coneybear.
 *************************************************/

function weeklyOSGetUiCastCoverageByRole_() {
  const result = {};

  const sheet =
    weeklyOSGetSheetSafe_(
      "Cast List"
    );

  if (!sheet) {
    return result;
  }

  const lastRow =
    sheet.getLastRow();

  if (lastRow < 3) {
    return result;
  }

  /*
   * Read A:F.
   */
  const values =
    sheet
      .getRange(
        3,
        1,
        lastRow - 2,
        6
      )
      .getDisplayValues();

  /*
   * Connect every short role to its full-character
   * name and vice versa.
   *
   * Example:
   * Leaf ↔ Leaf Coneybear
   * Barfée ↔ William Barfée
   */
  const aliasesByRole = {};

  values.forEach(function (row) {
    const castType =
      weeklyOSNormalizeText_(
        row[0]
      );

    const fullCharacter =
      weeklyOSNormalizeText_(
        row[3]
      );

    const shortRole =
      weeklyOSNormalizeText_(
        row[4] || row[0]
      );

    if (
      !shortRole ||
      weeklyOSUpper_(castType)
        .indexOf("SWING") >= 0
    ) {
      return;
    }

    const aliases =
      weeklyOSUniqueStrings_([
        castType,
        shortRole,
        fullCharacter
      ]);

    aliases.forEach(function (alias) {
      const key =
        weeklyOSCoverageRoleKey_(
          alias
        );

      if (!key) {
        return;
      }

      aliasesByRole[key] =
        weeklyOSUniqueStrings_(
          aliases
        );
    });
  });

  /*
   * Read every performer with entries in COVERS.
   */
  values.forEach(function (row) {
    const fullName =
      weeklyOSNormalizeText_(
        row[1]
      );

    const coversText =
      weeklyOSNormalizeText_(
        row[5]
      );

    if (
      !fullName ||
      !coversText
    ) {
      return;
    }

    const covers =
      String(row[5] || "")
        .split(/\n|,|;/)
        .map(weeklyOSNormalizeText_)
        .filter(Boolean);

    covers.forEach(function (coveredRole) {
      const coveredKey =
        weeklyOSCoverageRoleKey_(
          coveredRole
        );

      if (!coveredKey) {
        return;
      }

      const aliases =
        aliasesByRole[coveredKey] ||
        [coveredRole];

      aliases.forEach(function (alias) {
        weeklyOSAddEligibleCastCover_(
          result,
          alias,
          fullName
        );
      });

      /*
       * Also save directly under the exact text found
       * in the COVERS cell.
       */
      weeklyOSAddEligibleCastCover_(
        result,
        coveredRole,
        fullName
      );
    });
  });

  /*
   * TEMPORARY RULE:
   *
   * Fernell Hogan is Justin Cooley's temporary
   * replacement and therefore must appear as an
   * eligible Leaf cover until Company Wizard is
   * completed.
   */
  [
    "Leaf",
    "Leaf Coneybear"
  ].forEach(function (role) {
    weeklyOSAddEligibleCastCover_(
      result,
      role,
      "Fernell Hogan"
    );
  });

  /*
   * Deduplicate and alphabetize each dropdown.
   */
  Object.keys(result).forEach(function (key) {
    result[key] =
      weeklyOSUniqueStrings_(
        result[key]
      ).sort(function (first, second) {
        return first.localeCompare(second);
      });
  });

  return result;
}


function weeklyOSAddEligibleCastCover_(
  result,
  role,
  actorName
) {
  const roleKey =
    weeklyOSCoverageRoleKey_(
      role
    );

  const cleanActor =
    weeklyOSNormalizeText_(
      actorName
    );

  if (
    !roleKey ||
    !cleanActor
  ) {
    return;
  }

  if (!result[roleKey]) {
    result[roleKey] = [];
  }

  result[roleKey].push(
    cleanActor
  );
}


function weeklyOSCoverageRoleKey_(
  value
) {
  return weeklyOSNormalizeText_(
    value
  )
    .toLowerCase()
    .replace(/[éèêë]/g, "e")
    .replace(/[^a-z0-9]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}



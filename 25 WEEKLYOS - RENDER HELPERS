/*************************************************
 * BUILD TIME RANGE
 *************************************************/

function weeklyOSBuildTimeRange_(
  startTime,
  endTime
) {
  const start =
    weeklyOSNormalizeDisplayTime_(
      startTime
    );

  const end =
    weeklyOSNormalizeDisplayTime_(
      endTime
    );

  if (
    start &&
    end
  ) {
    return (
      start +
      " - " +
      end
    );
  }

  return (
    start ||
    end ||
    ""
  );
}


/*************************************************
 * NORMALIZE DISPLAY TIME
 *
 * This stays intentionally forgiving because the
 * source sheets may contain:
 *
 * 7:00 PM
 * 7pm
 * 7 PM
 * 12:30pm
 * Noon
 * TBD
 *************************************************/

function weeklyOSNormalizeDisplayTime_(
  value
) {
  const text =
    weeklyOSNormalizeText_(
      value
    );

  if (!text) {
    return "";
  }

  const upper =
    weeklyOSUpper_(
      text
    );

  if (
    upper === "NOON" ||
    upper === "MIDNIGHT" ||
    upper === "TBD"
  ) {
    return upper === "TBD"
      ? "TBD"
      : (
        upper.charAt(0) +
        upper
          .slice(1)
          .toLowerCase()
      );
  }

  const match =
    text.match(
      /^(\d{1,2})(?::(\d{2}))?\s*(AM|PM)?$/i
    );

  if (!match) {
    return text;
  }

  const hour =
    Number(
      match[1]
    );

  const minute =
    match[2] == null
      ? "00"
      : String(
          match[2]
        ).padStart(
          2,
          "0"
        );

  const meridiem =
    match[3]
      ? weeklyOSUpper_(
          match[3]
        )
      : "";

  return (
    hour +
    ":" +
    minute +
    (
      meridiem
        ? " " +
          meridiem
        : ""
    )
  );
}


/*************************************************
 * BUILD LOCATION TEXT
 *************************************************/

function weeklyOSBuildLocationText_(
  title,
  location
) {
  const cleanTitle =
    weeklyOSNormalizeText_(
      title
    );

  const cleanLocation =
    weeklyOSNormalizeText_(
      location
    );

  if (
    cleanTitle &&
    cleanLocation
  ) {
    return (
      cleanTitle +
      " (" +
      cleanLocation +
      ")"
    );
  }

  return (
    cleanTitle ||
    cleanLocation ||
    ""
  );
}


/*************************************************
 * FORMAT OUT SCOPE FOR WEEKLY
 *************************************************/

function weeklyOSFormatOutScopeForWeekly_(
  scope
) {
  const normalized =
    weeklyOSUpper_(
      scope
    );

  const labels = {
    ALL:
      "",

    MAT:
      "Mat ONLY",

    EVE:
      "Eve ONLY",

    "MAT & EVE":
      "Mat & Eve",

    "REHEARSAL & PERFORMANCE":
      "Rehearsal & Performance",

    "PUT-IN & PERFORMANCE":
      "Put-In & Performance"
  };

  if (
    Object.prototype
      .hasOwnProperty
      .call(
        labels,
        normalized
      )
  ) {
    return labels[
      normalized
    ];
  }

  return weeklyOSNormalizeText_(
    scope
  );
}


/*************************************************
 * ABBREVIATE PERSON NAME
 *
 * Justin Cooley → Justin C.
 * Liz Doran → Liz D.
 *
 * Existing abbreviated names such as "Liz D."
 * remain unchanged.
 *************************************************/

function weeklyOSAbbreviateName_(
  fullName
) {
  const normalized =
    weeklyOSNormalizeText_(
      fullName
    );

  if (!normalized) {
    return "";
  }

  if (
    /^[^\s]+\s+[A-Z]\.$/.test(
      normalized
    )
  ) {
    return normalized;
  }

  const parts =
    normalized.split(
      /\s+/
    );

  if (
    parts.length < 2
  ) {
    return normalized;
  }

  const firstName =
    parts[0];

  const lastName =
    parts[
      parts.length - 1
    ];

  const lastInitial =
    lastName
      .replace(
        /[^A-Za-zÀ-ÖØ-öø-ÿ]/g,
        ""
      )
      .charAt(0);

  if (!lastInitial) {
    return normalized;
  }

  return (
    firstName +
    " " +
    lastInitial
      .toUpperCase() +
    "."
  );
}


/*************************************************
 * TIME SUBTRACTION
 *************************************************/

function weeklyOSSubtractMinutesFromTime_(
  timeText,
  minutesToSubtract
) {
  const totalMinutes =
    weeklyOSTimeToMinutes_(
      timeText
    );

  if (
    totalMinutes === null
  ) {
    return "";
  }

  let adjusted =
    totalMinutes -
    Number(
      minutesToSubtract || 0
    );

  while (
    adjusted < 0
  ) {
    adjusted +=
      24 * 60;
  }

  adjusted =
    adjusted %
    (24 * 60);

  return weeklyOSMinutesToDisplayTime_(
    adjusted
  );
}


/*************************************************
 * MINUTES TO DISPLAY TIME
 *************************************************/

function weeklyOSMinutesToDisplayTime_(
  totalMinutes
) {
  const numeric =
    Number(
      totalMinutes
    );

  if (
    isNaN(numeric)
  ) {
    return "";
  }

  const normalized =
    (
      numeric %
      (24 * 60) +
      24 * 60
    ) %
    (24 * 60);

  const hour24 =
    Math.floor(
      normalized / 60
    );

  const minute =
    normalized % 60;

  const meridiem =
    hour24 >= 12
      ? "PM"
      : "AM";

  let hour12 =
    hour24 % 12;

  if (
    hour12 === 0
  ) {
    hour12 = 12;
  }

  return (
    hour12 +
    ":" +
    String(
      minute
    ).padStart(
      2,
      "0"
    ) +
    " " +
    meridiem
  );
}


/*************************************************
 * DISPLAY DAY LABEL
 *************************************************/

function weeklyOSBuildRenderDayLabel_(
  day
) {
  if (!day) {
    return "";
  }

  return (
    day.dateLabel ||
    weeklyOSFormatDate_(
      day.date,
      "EEEE, MMMM d"
    )
  );
}


/*************************************************
 * DISPLAY NOTE BULLET
 *************************************************/

function weeklyOSBuildRenderNoteBullet_(
  note
) {
  if (!note) {
    return "";
  }

  const text =
    typeof note ===
      "string"
      ? note
      : note.text;

  const normalized =
    weeklyOSNormalizeMultilineText_(
      text
    );

  if (!normalized) {
    return "";
  }

  if (
    normalized.indexOf(
      "- "
    ) === 0
  ) {
    return normalized;
  }

  return (
    "- " +
    normalized
  );
}


/*************************************************
 * FIND STYLE DEFINITION
 *************************************************/

function weeklyOSGetRenderStyle_(
  styleName
) {
  const styles =
    weeklyOSGetRenderStyles_();

  const normalized =
    weeklyOSUpper_(
      styleName ||
      "STANDARD"
    );

  return (
    styles[
      normalized
    ] ||
    styles.STANDARD
  );
}


/*************************************************
 * CHECK IF ITEM IS NEW-ACTOR CONTENT
 *************************************************/

function weeklyOSRenderItemIsNewActor_(
  item
) {
  return Boolean(
    item &&
    weeklyOSUpper_(
      item.style
    ) ===
      "NEW_ACTOR"
  );
}


/*************************************************
 * CHECK IF ROW IS DIVIDER
 *************************************************/

function weeklyOSRenderRowIsDivider_(
  row
) {
  return Boolean(
    row &&
    (
      weeklyOSUpper_(
        row.rowType
      ) ===
        "DIVIDER" ||
      weeklyOSUpper_(
        row.style
      ) ===
        "GOLD_DIVIDER"
    )
  );
}


/*************************************************
 * CHECK IF DAY HAS NOTES
 *************************************************/

function weeklyOSComposedDayHasNotes_(
  composedDay
) {
  return Boolean(
    composedDay &&
    Array.isArray(
      composedDay.notes
    ) &&
    composedDay.notes.some(
      function (note) {
        return Boolean(
          note &&
          note.text
        );
      }
    )
  );
}


/*************************************************
 * BUILD SIMPLE COMPOSED-DAY SUMMARY
 *************************************************/

function weeklyOSBuildComposedDaySummary_(
  composedDay
) {
  if (!composedDay) {
    return null;
  }

  return {
    date:
      composedDay.date,

    templateType:
      composedDay.templateType,

    headerText:
      composedDay.headerText,

    timelineRows:
      Array.isArray(
        composedDay.timeline
      )
        ? composedDay
            .timeline
            .length
        : 0,

    noteCount:
      Array.isArray(
        composedDay.notes
      )
        ? composedDay
            .notes
            .length
        : 0,

    hasGoldDivider:
      Boolean(
        composedDay.rendering &&
        composedDay.rendering
          .hasGoldDivider
      ),

    hasNewActorContent:
      Boolean(
        composedDay.rendering &&
        composedDay.rendering
          .hasNewActorContent
      ),

    hideGuestSpeller:
      Boolean(
        composedDay.rendering &&
        composedDay.rendering
          .hideGuestSpeller
      )
  };
}


/*************************************************
 * BUILD FULL COMPOSITION SUMMARY
 *************************************************/

function weeklyOSBuildCompositionSummary_(
  composedDraft
) {
  if (!composedDraft) {
    return null;
  }

  const composedDays =
    composedDraft.composition &&
    Array.isArray(
      composedDraft.composition
        .days
    )
      ? composedDraft
          .composition
          .days
      : [];

  return {
    weekStart:
      composedDraft.weekStart,

    weekEnd:
      composedDraft.weekEnd,

    composedAt:
      composedDraft.composition
        ? composedDraft
            .composition
            .composedAt
        : "",

    days:
      composedDays.map(
        weeklyOSBuildComposedDaySummary_
      ),

    totals: {
      timelineRows:
        composedDays.reduce(
          function (
            total,
            day
          ) {
            return (
              total +
              (
                Array.isArray(
                  day.timeline
                )
                  ? day
                      .timeline
                      .length
                  : 0
              )
            );
          },
          0
        ),

      notes:
        composedDays.reduce(
          function (
            total,
            day
          ) {
            return (
              total +
              (
                Array.isArray(
                  day.notes
                )
                  ? day.notes
                      .length
                  : 0
              )
            );
          },
          0
        ),

      newActorDays:
        composedDays.filter(
          function (day) {
            return Boolean(
              day.rendering &&
              day.rendering
                .hasNewActorContent
            );
          }
        ).length
    }
  };
}

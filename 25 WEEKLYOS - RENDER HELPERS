/*************************************************
 * PUBLIC API
 *************************************************/

function WeeklyRenderOS() {
  return {
    version:
      "0.1.0",

    styles:
      weeklyOSGetRenderStyles_(),

    dayTemplates:
      weeklyOSGetDayTemplateDefinitions_(),

    createRow:
      weeklyOSCreateRenderRow_,

    createNote:
      weeklyOSCreateRenderNote_,

    abbreviateName:
      weeklyOSAbbreviateName_,

    subtractMinutes:
      weeklyOSSubtractMinutesFromTime_
  };
}


/*************************************************
 * CREATE RENDER ROW
 *
 * A render row is the normalized structure that
 * the future generator will write into the weekly
 * schedule grid.
 *************************************************/

function weeklyOSCreateRenderRow_(
  input
) {
  input =
    input || {};

  return {
    id:
      input.id ||
      weeklyOSUuid_(),

    rowType:
      weeklyOSNormalizeText_(
        input.rowType ||
        "STANDARD"
      ),

    time:
      weeklyOSNormalizeText_(
        input.time
      ),

    activity:
      String(
        input.activity == null
          ? ""
          : input.activity
      ),

    called:
      weeklyOSNormalizeText_(
        input.called
      ),

    style:
      weeklyOSNormalizeText_(
        input.style ||
        "STANDARD"
      ),

    sourceId:
      weeklyOSNormalizeText_(
        input.sourceId
      ),

    metadata:
      input.metadata &&
      typeof input.metadata ===
        "object"
        ? weeklyOSDeepClone_(
            input.metadata
          )
        : {}
  };
}


/*************************************************
 * CREATE RENDER NOTE
 *************************************************/

function weeklyOSCreateRenderNote_(
  input
) {
  input =
    input || {};

  return {
    id:
      input.id ||
      weeklyOSUuid_(),

    category:
      weeklyOSNormalizeText_(
        input.category ||
        "GENERAL"
      ),

    text:
      weeklyOSNormalizeMultilineText_(
        input.text
      ),

    style:
      weeklyOSNormalizeText_(
        input.style ||
        "STANDARD"
      ),

    sourceId:
      weeklyOSNormalizeText_(
        input.sourceId
      ),

    metadata:
      input.metadata &&
      typeof input.metadata ===
        "object"
        ? weeklyOSDeepClone_(
            input.metadata
          )
        : {}
  };
}


/*************************************************
 * NORMALIZE MULTILINE TEXT
 *
 * Unlike weeklyOSNormalizeText_(), this preserves
 * intentional line breaks for Put-In assignments
 * and performance blocks.
 *************************************************/

function weeklyOSNormalizeMultilineText_(
  value
) {
  return String(
    value == null
      ? ""
      : value
  )
    .replace(
      /\u00A0/g,
      " "
    )
    .replace(
      /\r\n/g,
      "\n"
    )
    .replace(
      /\r/g,
      "\n"
    )
    .split("\n")
    .map(
      function (line) {
        return line
          .replace(
            /[ \t]+/g,
            " "
          )
          .trim();
      }
    )
    .filter(
      function (
        line,
        index,
        lines
      ) {
        /*
         * Preserve a single intentional blank line,
         * but avoid repeated blank rows.
         */
        if (line) {
          return true;
        }

        return (
          index > 0 &&
          index <
            lines.length - 1 &&
          lines[index - 1] !==
            ""
        );
      }
    )
    .join("\n")
    .trim();
}



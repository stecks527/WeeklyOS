/*************************************************
 * 25 WEEKLYOS - ROLE REGISTRY
 * Version: 0.2.0
 *
 * PURPOSE
 * A name-free role registry for WeeklyOS.
 *
 * This file defines:
 * - which staff roles exist
 * - which roles belong to which department/team
 * - which roles can affect performance staffing
 * - the structured rehearsal staffing model
 *
 * It does NOT:
 * - hard-code any person's name
 * - treat the Contact Sheet as a database
 * - write to Weekly Schedule
 * - assign a specific person to a role
 *
 * FUTURE COMPANYOS
 * CompanyOS will eventually answer:
 *   "Who currently occupies this role?"
 *
 * WeeklyOS will continue using the same role keys.
 *************************************************/


/*************************************************
 * PUBLIC API
 *************************************************/

function WeeklyRoleOS() {
  return {
    version: "0.2.0",

    getRegistry:
      weeklyOSGetRoleRegistry_,

    getRole:
      weeklyOSGetRoleDefinition_,

    getRolesByTeam:
      weeklyOSGetRolesByTeam_,

    getRehearsalStaffOptions:
      weeklyOSGetRehearsalStaffOptions_,

    normalizeRehearsal:
      weeklyOSNormalizeRehearsalModel_,

    buildStaffingImpact:
      weeklyOSBuildRoleBasedStaffingImpact_,

    buildOperationalNote:
      weeklyOSBuildRoleBasedOperationalNote_
  };
}



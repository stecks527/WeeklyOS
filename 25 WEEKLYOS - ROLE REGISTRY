/*************************************************
 * ROLE LOOKUPS
 *************************************************/

function weeklyOSGetRoleDefinition_(roleKey) {
  const registry =
    weeklyOSGetRoleRegistry_();

  const key =
    weeklyOSNormalizeRoleKey_(roleKey);

  return registry.roles[key] || null;
}


function weeklyOSGetRolesByTeam_(teamKey) {
  const registry =
    weeklyOSGetRoleRegistry_();

  const wantedTeam =
    weeklyOSNormalizeRoleKey_(teamKey);

  return Object.keys(registry.roles)
    .map(function (key) {
      return registry.roles[key];
    })
    .filter(function (role) {
      return (
        role.teamKey === wantedTeam
      );
    })
    .sort(function (a, b) {
      return (
        Number(a.sortOrder || 0) -
        Number(b.sortOrder || 0)
      );
    });
}


function weeklyOSGetRehearsalStaffOptions_() {
  const registry =
    weeklyOSGetRoleRegistry_();

  const teams =
    Object.keys(registry.teams)
      .map(function (key) {
        return registry.teams[key];
      })
      .sort(function (a, b) {
        return (
          Number(a.sortOrder || 0) -
          Number(b.sortOrder || 0)
        );
      });

  return teams.map(function (team) {
    return {
      key: team.key,
      label: team.label,

      roles:
        weeklyOSGetRolesByTeam_(
          team.key
        )
          .filter(function (role) {
            return role.rehearsalEligible;
          })
          .map(function (role) {
            return {
              key: role.key,
              label: role.label,
              shortLabel:
                role.shortLabel
            };
          })
    };
  });
}


/*************************************************
 * STRUCTURED REHEARSAL MODEL
 *************************************************/

function weeklyOSNormalizeRehearsalModel_(
  rehearsal
) {
  const source =
    rehearsal || {};

  const normalized = {
    id:
      source.id || "",

    type:
      weeklyOSCleanRoleText_(
        source.type ||
        source.rehearsalType
      ),

    title:
      weeklyOSCleanRoleText_(
        source.title ||
        source.name
      ),

    startTime:
      weeklyOSCleanRoleText_(
        source.startTime ||
        source.start
      ),

    endTime:
      weeklyOSCleanRoleText_(
        source.endTime ||
        source.end
      ),

    location: {
      venue:
        weeklyOSCleanRoleText_(
          source.location &&
          typeof source.location ===
            "object"
            ? source.location.venue
            : source.location
        ),

      address1:
        weeklyOSCleanRoleText_(
          source.location &&
          typeof source.location ===
            "object"
            ? source.location.address1
            : source.address1
        ),

      address2:
        weeklyOSCleanRoleText_(
          source.location &&
          typeof source.location ===
            "object"
            ? source.location.address2
            : source.address2
        )
    },

    staffCalled:
      weeklyOSNormalizeStaffAssignments_(
        source.staffCalled || []
      ),

    actorsCalled:
      weeklyOSUniqueRoleTextList_(
        source.actorsCalled ||
        source.actorCall ||
        []
      ),

    notes:
      weeklyOSUniqueRoleTextList_(
        source.notes || []
      ),

    performanceStaffing:
      weeklyOSNormalizePerformanceStaffing_(
        source.performanceStaffing
      )
  };

  return normalized;
}


function weeklyOSNormalizeStaffAssignments_(
  assignments
) {
  return (assignments || [])
    .map(function (assignment) {
      if (
        typeof assignment ===
        "string"
      ) {
        return {
          roleKey:
            weeklyOSNormalizeRoleKey_(
              assignment
            ),

          personId: "",
          personName: "",
          displayLabel:
            weeklyOSCleanRoleText_(
              assignment
            )
        };
      }

      const roleKey =
        weeklyOSNormalizeRoleKey_(
          assignment.roleKey ||
          assignment.role ||
          assignment.title
        );

      const role =
        weeklyOSGetRoleDefinition_(
          roleKey
        );

      return {
        roleKey: roleKey,

        /*
         * These are intentionally optional.
         * CompanyOS will fill them later.
         */
        personId:
          weeklyOSCleanRoleText_(
            assignment.personId
          ),

        personName:
          weeklyOSCleanRoleText_(
            assignment.personName ||
            assignment.name
          ),

        displayLabel:
          weeklyOSCleanRoleText_(
            assignment.displayLabel
          ) ||
          (
            role
              ? role.label
              : weeklyOSCleanRoleText_(
                  assignment.role ||
                  assignment.title
                )
          )
      };
    })
    .filter(function (assignment) {
      return Boolean(
        assignment.roleKey ||
        assignment.personName ||
        assignment.displayLabel
      );
    });
}


function weeklyOSNormalizePerformanceStaffing_(
  staffing
) {
  const source =
    staffing || {};

  return {
    applies:
      Boolean(source.applies),

    reason:
      weeklyOSCleanRoleText_(
        source.reason
      ),

    affectedPerformanceIds:
      weeklyOSUniqueRoleTextList_(
        source.affectedPerformanceIds ||
        []
      ),

    performanceScope:
      weeklyOSCleanRoleText_(
        source.performanceScope
      ),

    unavailableRoleKeys:
      weeklyOSUniqueRoleKeyList_(
        source.unavailableRoleKeys ||
        []
      ),

    assignments:
      weeklyOSNormalizeStaffAssignments_(
        source.assignments || []
      ),

    requiresReview:
      Boolean(
        source.requiresReview
      ),

    generatedNote:
      weeklyOSCleanRoleText_(
        source.generatedNote
      ),

    note:
      weeklyOSCleanRoleText_(
        source.note
      )
  };
}


/*************************************************
 * ROLE-BASED PERFORMANCE STAFFING
 *
 * This determines the required role movement.
 * It does not guess which person fills the role.
 *************************************************/

function weeklyOSBuildRoleBasedStaffingImpact_(
  rehearsal,
  day
) {
  const normalized =
    weeklyOSNormalizeRehearsalModel_(
      rehearsal
    );

  const performances =
    day &&
    Array.isArray(
      day.performances
    )
      ? day.performances
      : [];

  const psmCalled =
    weeklyOSHasStaffRole_(
      normalized.staffCalled,
      "PRODUCTION_STAGE_MANAGER"
    );

  const affected =
    psmCalled &&
    performances.length > 0;

  const existing =
    normalized.performanceStaffing;

  const assignments =
    weeklyOSMergeStaffingAssignments_(
      existing.assignments,
      affected
        ? [
            {
              roleKey:
                "CALLING_PSM",

              sourceRoleKey:
                "ASSISTANT_STAGE_MANAGER",

              personId: "",
              personName: "",
              displayLabel:
                "Current ASM becomes Calling PSM"
            },

            {
              roleKey:
                "DECK_ASM",

              sourceRoleKey:
                "SUB_STAGE_MANAGER",

              personId: "",
              personName: "",
              displayLabel:
                "ASM coverage required"
            }
          ]
        : []
    );

  const impact = {
    applies:
      affected,

    reason:
      affected
        ? "PRODUCTION_STAGE_MANAGER_CALLED_TO_REHEARSAL_ON_PERFORMANCE_DAY"
        : "",

    affectedPerformanceIds:
      performances.map(function (
        performance
      ) {
        return weeklyOSCleanRoleText_(
          performance.id ||
          performance.performanceNumber ||
          performance.label ||
          performance.time
        );
      }).filter(Boolean),

    performanceScope:
      weeklyOSGetPerformanceScope_(
        performances
      ),

    unavailableRoleKeys:
      affected
        ? [
            "PRODUCTION_STAGE_MANAGER"
          ]
        : [],

    assignments:
      assignments,

    requiresReview:
      affected &&
      assignments.some(function (
        assignment
      ) {
        return (
          !assignment.personId &&
          !assignment.personName
        );
      }),

    generatedNote:
      "",

    note:
      existing.note || ""
  };

  impact.generatedNote =
    weeklyOSBuildRoleBasedOperationalNote_(
      impact
    );

  if (!impact.note) {
    impact.note =
      impact.generatedNote;
  }

  return impact;
}


/*************************************************
 * OPERATIONAL NOTE
 *
 * Uses assigned person names when available.
 * Otherwise uses role labels/TBD.
 *************************************************/

function weeklyOSBuildRoleBasedOperationalNote_(
  impact
) {
  if (
    !impact ||
    !impact.applies
  ) {
    return "";
  }

  const psmUnavailable =
    weeklyOSFindAssignmentForRole_(
      impact.assignments,
      "UNAVAILABLE_PSM"
    );

  const callingPsm =
    weeklyOSFindAssignmentForRole_(
      impact.assignments,
      "CALLING_PSM"
    );

  const deckAsm =
    weeklyOSFindAssignmentForRole_(
      impact.assignments,
      "DECK_ASM"
    );

  const unavailableLabel =
    weeklyOSAssignmentPersonLabel_(
      psmUnavailable
    ) ||
    "PSM";

  const callingLabel =
    weeklyOSAssignmentPersonLabel_(
      callingPsm
    ) ||
    "Current ASM";

  const deckLabel =
    weeklyOSAssignmentPersonLabel_(
      deckAsm
    ) ||
    "TBD";

  const scope =
    weeklyOSCleanRoleText_(
      impact.performanceScope
    );

  return (
    "- " +
    unavailableLabel +
    " at Rehearsal. " +
    callingLabel +
    " = PSM, " +
    deckLabel +
    " IN as ASM" +
    (
      scope
        ? " (" + scope + ")"
        : ""
    )
  );
}


/*************************************************
 * ASSIGNMENT HELPERS
 *************************************************/

function weeklyOSHasStaffRole_(
  staffCalled,
  roleKey
) {
  const wanted =
    weeklyOSNormalizeRoleKey_(
      roleKey
    );

  return (staffCalled || [])
    .some(function (assignment) {
      return (
        weeklyOSNormalizeRoleKey_(
          assignment.roleKey
        ) === wanted
      );
    });
}


function weeklyOSMergeStaffingAssignments_(
  existing,
  defaults
) {
  const result = [];
  const seen = {};

  []
    .concat(existing || [])
    .concat(defaults || [])
    .forEach(function (assignment) {
      const normalized = {
        roleKey:
          weeklyOSNormalizeRoleKey_(
            assignment.roleKey
          ),

        sourceRoleKey:
          weeklyOSNormalizeRoleKey_(
            assignment.sourceRoleKey
          ),

        personId:
          weeklyOSCleanRoleText_(
            assignment.personId
          ),

        personName:
          weeklyOSCleanRoleText_(
            assignment.personName
          ),

        displayLabel:
          weeklyOSCleanRoleText_(
            assignment.displayLabel
          )
      };

      const key =
        normalized.roleKey ||
        normalized.displayLabel;

      if (!key) {
        return;
      }

      if (!seen[key]) {
        seen[key] =
          normalized;

        result.push(
          normalized
        );

        return;
      }

      /*
       * A manual assignment wins over a generated default.
       */
      if (
        normalized.personId ||
        normalized.personName
      ) {
        Object.assign(
          seen[key],
          normalized
        );
      }
    });

  return result;
}


function weeklyOSFindAssignmentForRole_(
  assignments,
  roleKey
) {
  const wanted =
    weeklyOSNormalizeRoleKey_(
      roleKey
    );

  return (assignments || [])
    .find(function (assignment) {
      return (
        weeklyOSNormalizeRoleKey_(
          assignment.roleKey
        ) === wanted
      );
    }) || null;
}


function weeklyOSAssignmentPersonLabel_(
  assignment
) {
  if (!assignment) {
    return "";
  }

  return weeklyOSCleanRoleText_(
    assignment.personName ||
    assignment.displayLabel
  );
}


/*************************************************
 * PERFORMANCE SCOPE
 *************************************************/

function weeklyOSGetPerformanceScope_(
  performances
) {
  const labels =
    (performances || [])
      .map(function (performance) {
        const text =
          weeklyOSCleanRoleText_(
            [
              performance.showType,
              performance.label,
              performance.time
            ]
              .filter(Boolean)
              .join(" ")
          ).toUpperCase();

        if (
          /\bMAT\b|\bMATINEE\b/.test(
            text
          )
        ) {
          return "Mat";
        }

        if (
          /\bEVE\b|\bEVENING\b/.test(
            text
          )
        ) {
          return "Eve";
        }

        return "";
      })
      .filter(Boolean);

  const unique =
    weeklyOSUniqueRoleTextList_(
      labels
    );

  if (
    unique.indexOf("Mat") !== -1 &&
    unique.indexOf("Eve") !== -1
  ) {
    return "Mat & Eve";
  }

  if (unique.length === 1) {
    return unique[0];
  }

  if (
    performances &&
    performances.length === 1
  ) {
    return "Performance";
  }

  if (
    performances &&
    performances.length > 1
  ) {
    return "Performances";
  }

  return "";
}


/*************************************************
 * TEXT HELPERS
 *************************************************/

function weeklyOSNormalizeRoleKey_(
  value
) {
  return String(
    value == null
      ? ""
      : value
  )
    .trim()
    .toUpperCase()
    .replace(
      /[^A-Z0-9]+/g,
      "_"
    )
    .replace(
      /^_+|_+$/g,
      ""
    );
}


function weeklyOSUniqueRoleKeyList_(
  values
) {
  const output = [];
  const seen = {};

  (values || [])
    .forEach(function (value) {
      const key =
        weeklyOSNormalizeRoleKey_(
          value
        );

      if (
        key &&
        !seen[key]
      ) {
        seen[key] = true;
        output.push(key);
      }
    });

  return output;
}


function weeklyOSUniqueRoleTextList_(
  values
) {
  const output = [];
  const seen = {};

  (values || [])
    .forEach(function (value) {
      const text =
        weeklyOSCleanRoleText_(
          value
        );

      const key =
        text.toUpperCase();

      if (
        text &&
        !seen[key]
      ) {
        seen[key] = true;
        output.push(text);
      }
    });

  return output;
}


function weeklyOSCleanRoleText_(
  value
) {
  return String(
    value == null
      ? ""
      : value
  )
    .replace(/\s+/g, " ")
    .trim();
}



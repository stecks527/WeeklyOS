 *************************************************/


/*************************************************
 * CREATE WEEK DRAFT
 *************************************************/

function weeklyOSCreateWeekDraft_(weekStart) {
  const start = weeklyOSFindMonday_(
    weekStart || weeklyOSNextMonday_()
  );

  const end = weeklyOSAddDays_(start, 6);

  const draft = {
    schemaVersion: 2,

    id: weeklyOSUuid_(),

    revision: 1,

    status: "IN_PROGRESS",

    createdAt: weeklyOSNowIso_(),

    updatedAt: weeklyOSNowIso_(),

    weekStart: weeklyOSDateKey_(start),

    weekEnd: weeklyOSDateKey_(end),

    title:
      "Build Weekly Schedule — " +
      weeklyOSFormatDate_(start, "MMMM d") +
      "–" +
      weeklyOSFormatDate_(end, "d, yyyy"),

    sourceStatus: {
      expandedCalendar:
        weeklyOSCreateSourceStatus_(
          "Expanded Calendar"
        ),

      productionCalendar:
        weeklyOSCreateSourceStatus_(
          "Production Calendar"
        ),

      pdVacationTracker:
        weeklyOSCreateSourceStatus_(
          "PD/Vacation Tracker"
        ),

      crewOuts:
        weeklyOSCreateSourceStatus_(
          "Crew Outs"
        ),

      contactSheet:
        weeklyOSCreateSourceStatus_(
          "Contact Sheet"
        ),

      newHireActivity:
        weeklyOSCreateSourceStatus_(
          "New-hire activity"
        )
    },

    days: [],

    observations: [],

    validation: {
      isValid: false,
      errors: [],
      warnings: []
    },

    metadata: {
      generatedSheetId: null,
      generatedSheetName: null,
      generatedAt: null,
      lastSourceRefreshAt: null
    }
  };

  for (let offset = 0; offset < 7; offset++) {
    draft.days.push(
      weeklyOSCreateDayDraft_(
        weeklyOSAddDays_(start, offset),
        offset
      )
    );
  }

  return draft;
}


/*************************************************
 * CREATE SOURCE STATUS
 *************************************************/

function weeklyOSCreateSourceStatus_(label) {
  return {
    label: label,
    found: false,
    status: "NOT_CHECKED",
    details: "",
    checkedAt: null

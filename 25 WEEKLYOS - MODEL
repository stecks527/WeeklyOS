/*************************************************
 * FIND DAY
 *************************************************/

function weeklyOSGetDay_(draft, dateValue) {
  if (
    !draft ||
    !Array.isArray(draft.days)
  ) {
    return null;
  }

  const dateKey =
    weeklyOSDateKey_(
      dateValue
    );

  return draft.days.find(
    function (day) {
      return day.date === dateKey;
    }
  ) || null;
}


/*************************************************
 * RECALCULATE FULL DRAFT
 *************************************************/

function weeklyOSRecalculateDraft_(draft) {
  if (!draft) {
    throw new Error(
      "WeeklyOS cannot recalculate an empty draft."
    );
  }

  draft.updatedAt =
    weeklyOSNowIso_();

  draft.days =
    Array.isArray(draft.days)
      ? draft.days
      : [];

  draft.days.forEach(
    function (day) {
      weeklyOSRecalculateDay_(day);
    }
  );

  const existingObservations =
    Array.isArray(draft.observations)
      ? draft.observations
      : [];

  const calculatedObservations =
    weeklyOSCollectObservations_(
      draft
    );

  draft.observations =
    weeklyOSMergeObservations_(
      existingObservations,
      calculatedObservations
    );

  draft.validation =
    weeklyOSValidateDraft(
      draft
    );

  return draft;
}


/*************************************************
 * RECALCULATE DAY
 *************************************************/

function weeklyOSRecalculateDay_(day) {
  weeklyOSEnsureDayModel_(day);

  const labels = [];
  const issues = [];

  if (day.dayOff) {
    labels.push("NO_PERFORMANCE");
    labels.push("DAY_OFF");
  } else if (!day.performances.length) {
    labels.push("NO_PERFORMANCE");
  } else if (day.performances.length > 1) {
    labels.push("TWO_SHOW_DAY");
  } else {
    labels.push("STANDARD");
  }

  if (
    day.rehearsals.length ||
    day.meetings.length ||
    day.workCalls.length ||
    day.putIns.length
  ) {
    labels.push("SCHEDULE_CHANGE");
  }

  if (day.rehearsals.some(function (item) {
    return item.type === "NEW_HIRE";
  })) {
    labels.push("NEW_HIRE_REHEARSAL");
  }

  if (day.putIns.length) {
    labels.push("PUT_IN");
  }

  if (day.companyEvents.length) {
    labels.push("COMPANY_ACTIVITY");
  }

  if (
    day.castOuts.length ||
    day.crewOuts.length
  ) {
    labels.push("OUTS_DETECTED");
  }

  if (day.pt.length) {
    labels.push("PT");
  }

  if (day.holidays.length) {
    labels.push("HOLIDAY");
  }

  if (day.rehearsals.some(function (item) {
    return item.requiresReview;
  })) {
    issues.push(
      "Rehearsal details need review."
    );
  }

  if (day.putIns.some(function (item) {
    return item.requiresReview;
  })) {
    issues.push(
      "Put-In details need review."
    );
  }

  if (day.companyEvents.some(function (item) {
    return item.requiresReview;
  })) {
    issues.push(
      "Company activity needs review."
    );
  }

  if (day.castOuts.some(function (item) {
    return (
      item.requiresReview &&
      !item.coverage
    );
  })) {
    issues.push(
      "Cast coverage is incomplete."
    );
  }

  if (day.crewOuts.some(function (item) {
    return (
      item.requiresReview &&
      !item.coverage
    );
  })) {
    issues.push(
      "Crew coverage is incomplete."
    );
  }

  if (day.rehearsals.some(function (item) {
    return (
      item.type === "NEW_HIRE" &&
      !item.location &&
      !item.canceled
    );
  })) {
    issues.push(
      "New-hire rehearsal location is missing."
    );
  }

  if (day.performances.some(function (item) {
    return !item.conductor;
  })) {
    issues.push(
      "A performance conductor is missing."
    );
  }

  if (issues.length) {
    labels.push("NEEDS_REVIEW");
    day.status = "NEEDS_REVIEW";
  } else if (day.reviewed) {
    day.status = "READY";
  } else {
    day.status = "UNREVIEWED";
  }

  const sourceChecks = [
    day.sources.expandedCalendar,
    day.sources.productionCalendar,
    day.sources.pdVacationTracker,
    day.sources.crewOuts
  ].filter(Boolean).length;

  let confidence =
    35 +
    sourceChecks * 12;

  if (
    day.performances.length ||
    day.dayOff
  ) {
    confidence += 10;
  }

  if (!issues.length) {
    confidence += 7;
  }

  if (day.reviewed) {
    confidence += 10;
  }

  day.statusLabels =
    weeklyOSUnique_(
      labels
    );

  day.confidence =
    Math.min(
      100,
      confidence
    );

  day.observations =
    weeklyOSUnique_(
      issues
    );

  return day;
}


/*************************************************
 * ENSURE COMPLETE DAY MODEL
 *************************************************/

function weeklyOSEnsureDayModel_(day) {
  const arrayFields = [
    "performances",
    "rehearsals",
    "meetings",
    "workCalls",
    "putIns",
    "companyEvents",
    "castOuts",
    "crewOuts",
    "pt",
    "holidays",
    "notes",
    "observations",
    "statusLabels"
  ];

  arrayFields.forEach(
    function (fieldName) {
      day[fieldName] =
        Array.isArray(day[fieldName])
          ? day[fieldName]
          : [];
    }
  );

  day.sources =
    day.sources || {};

  const sourceFields = [
    "expandedCalendar",
    "productionCalendar",
    "pdVacationTracker",
    "crewOuts",
    "contactSheet",
    "googleCalendar",
    "manual"
  ];

  sourceFields.forEach(
    function (fieldName) {
      day.sources[fieldName] =
        Boolean(
          day.sources[fieldName]
        );
    }
  );

  if (day.dayOff === undefined) {
    day.dayOff = null;
  }

  return day;
}


/*************************************************
 * COLLECT "THINGS I NOTICED"
 *************************************************/

function weeklyOSCollectObservations_(draft) {
  const observations = [];

  draft.days.forEach(
    function (day) {
      day.observations.forEach(
        function (detail) {
          if (!detail) return;

          observations.push(
            weeklyOSCreateObservation_({
              level: "WARNING",
              date: day.date,
              title: day.dateLabel,
              detail: detail,
              source: "WeeklyOS validation"
            })
          );
        }
      );

      day.performances.forEach(
        function (performance) {
          if (performance.guestSpeller) {
            observations.push(
              weeklyOSCreateObservation_({
                level: "INFO",
                date: day.date,
                title: "Guest Speller detected",
                detail:
                  performance.guestSpeller +
                  (
                    performance.performanceNumber
                      ? " — Performance #" +
                        performance.performanceNumber
                      : ""
                  ),
                source: performance.source
              })
            );
          }
        }
      );

      day.companyEvents.forEach(
        function (event) {
          observations.push(
            weeklyOSCreateObservation_({
              level:
                event.requiresReview
                  ? "WARNING"
                  : "INFO",

              date:
                day.date,

              title:
                event.title ||
                weeklyOSCompanyEventLabel_(
                  event.type
                ),

              detail:
                event.people.length
                  ? event.people.join(", ")
                  : event.notes,

              source:
                event.source
            })
          );
        }
      );

      if (day.putIns.length) {
        observations.push(
          weeklyOSCreateObservation_({
            level: "INFO",
            date: day.date,
            title: "Put-In detected",
            detail:
              day.putIns.length +
              " Put-In item(s) scheduled.",
            source: "WeeklyOS draft"
          })
        );
      }

      if (day.pt.length) {
        observations.push(
          weeklyOSCreateObservation_({
            level: "INFO",
            date: day.date,
            title: "PT scheduled",
            detail:
              day.pt.map(function (item) {
                return [
                  item.startTime,
                  item.endTime
                ]
                  .filter(Boolean)
                  .join("–");
              }).join(", "),
            source: "Expanded Calendar"
          })
        );
      }
    }
  );

  return observations;
}


/*************************************************
 * COMPANY EVENT LABEL
 *************************************************/

function weeklyOSCompanyEventLabel_(type) {
  const labels = {
    NEW_HIRE_START:
      "New hire start",

    FIRST_PERFORMANCE:
      "First performance",

    SCHEDULED_RETURN:
      "Scheduled return",

    FINAL_PERFORMANCE:
      "Final performance",

    WATCH_SHOW:
      "Watch Show",

    ONBOARDING:
      "Onboarding / Measurements",

    SPECIAL_EVENT:
      "Special event",

    COMPANY_MEETING:
      "Company meeting",

    OTHER:
      "Company activity"
  };

  return (
    labels[type] ||
    labels.OTHER
  );
}


/*************************************************
 * MERGE OBSERVATIONS
 *************************************************/

function weeklyOSMergeObservations_(
  existing,
  incoming
) {
  const merged = [];
  const seen = {};

  []
    .concat(
      Array.isArray(existing)
        ? existing
        : []
    )
    .concat(
      Array.isArray(incoming)
        ? incoming
        : []
    )
    .forEach(
      function (item) {
        if (!item) return;

        const key =
          weeklyOSObservationKey_(
            item
          );

        if (seen[key]) return;

        seen[key] = true;
        merged.push(item);
      }
    );

  return merged;
}


/*************************************************
 * OBSERVATION KEY
 *************************************************/

function weeklyOSObservationKey_(item) {
  if (
    typeof item === "string"
  ) {
    return item;
  }

  return [
    item.date || "",
    item.title || "",
    item.detail || "",
    item.source || ""
  ].join("|");
}


/*************************************************
 * NORMALIZE STRING ARRAY
 *************************************************/

function weeklyOSNormalizeStringArray_(values) {
  if (!Array.isArray(values)) {
    if (!values) return [];

    values =
      String(values)
        .split(",");
  }

  return weeklyOSUniqueStrings_(
    values
  );
}


/*************************************************
 * UNIQUE VALUES
 *************************************************/

function weeklyOSUnique_(values) {
  const seen = {};

  return (
    Array.isArray(values)
      ? values
      : []
  ).filter(
    function (value) {
      const key =
        value &&
        typeof value === "object"
          ? weeklyOSObservationKey_(value)
          : String(value);

      if (seen[key]) {
        return false;
      }

      seen[key] = true;
      return true;
    }
  );
}

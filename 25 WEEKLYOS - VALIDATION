    weeklyOSValidationDayLabel_(
      day
    );

  day.workCalls.forEach(
    function (
      workCall,
      index
    ) {
      const workCallLabel =
        workCall.title ||
        "Work Call " +
        (index + 1);

      if (!workCall.title) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "WORK_CALL_MISSING_TITLE",

            date:
              day.date,

            message:
              label +
              " contains a work call without a title."
          }
        );
      }

      if (!workCall.startTime) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "WORK_CALL_MISSING_START_TIME",

            date:
              day.date,

            message:
              label +
              ": " +
              workCallLabel +
              " does not have a start time."
          }
        );
      }

      if (!workCall.called.length) {
        weeklyOSAddValidationWarning_(

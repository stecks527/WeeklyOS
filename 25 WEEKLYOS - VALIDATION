          }
        );
      }
    }
  );
}


/*************************************************
 * VALIDATE PUT-INS
 *************************************************/

function weeklyOSValidatePutIns_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  day.putIns.forEach(
    function (
      putIn,
      index
    ) {
      const putInLabel =
        putIn.title ||
        "Put-In " +
        (index + 1);

      if (!putIn.title) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "PUT_IN_MISSING_TITLE",

            date:
              day.date,

            message:
              label +
              " contains a Put-In without a title."
          }
        );
      }

      if (!putIn.startTime) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "PUT_IN_MISSING_START_TIME",

            date:
              day.date,

            message:
              label +
              ": " +
              putInLabel +
              " does not have an overall start time."
          }
        );
      }

      if (!putIn.location) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "PUT_IN_MISSING_LOCATION",

            date:
              day.date,

            message:
              label +
              ": " +
              putInLabel +
              " does not have a location."
          }
        );
      }

      if (!putIn.segments.length) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "PUT_IN_MISSING_SEGMENTS",

            date:
              day.date,

            message:
              label +
              ": " +
              putInLabel +
              " does not contain any timed segments."
          }
        );
      }

      if (
        putIn.requiresReview
      ) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "PUT_IN_NEEDS_REVIEW",

            date:
              day.date,

            message:
              label +
              ": " +
              putInLabel +
              " still needs review."
          }
        );
      }

      putIn.segments.forEach(
        function (
          segment,
          segmentIndex
        ) {
          if (!segment.title) {
            weeklyOSAddValidationWarning_(
              result,
              {
                code:
                  "PUT_IN_SEGMENT_MISSING_TITLE",

                date:
                  day.date,

                message:
                  label +
                  ": segment " +
                  (segmentIndex + 1) +
                  " of " +
                  putInLabel +
                  " does not have a title."
              }
            );
          }

          if (!segment.startTime) {
            weeklyOSAddValidationWarning_(
              result,
              {
                code:
                  "PUT_IN_SEGMENT_MISSING_TIME",

                date:
                  day.date,

                message:
                  label +
                  ": " +
                  (
                    segment.title ||
                    "a Put-In segment"
                  ) +
                  " does not have a start time."
              }
            );
          }
        }
      );
    }
  );
}


/*************************************************
 * VALIDATE COMPANY EVENTS
 *************************************************/

function weeklyOSValidateCompanyEvents_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  day.companyEvents.forEach(
    function (
      event,
      index
    ) {
      const eventLabel =
        event.title ||
        weeklyOSCompanyEventLabel_(
          event.type
        ) ||
        "Company event " +
        (index + 1);

      if (!event.title) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "COMPANY_EVENT_MISSING_TITLE",

            date:
              day.date,

            message:
              label +
              " contains a company event without a title."
          }
        );
      }

      if (
        [
          "NEW_HIRE_START",
          "FIRST_PERFORMANCE",
          "SCHEDULED_RETURN",
          "FINAL_PERFORMANCE"
        ].indexOf(
          event.type
        ) >= 0 &&
        !event.people.length
      ) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "COMPANY_EVENT_MISSING_PEOPLE",

            date:
              day.date,

            message:
              label +
              ": " +
              eventLabel +
              " does not identify a person."
          }
        );
      }

      if (
        event.requiresReview
      ) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "COMPANY_EVENT_NEEDS_REVIEW",

            date:
              day.date,

            message:
              label +
              ": " +
              eventLabel +
              " should be reviewed."
          }
        );
      }
    }
  );
}


/*************************************************
 * VALIDATE CAST OUTS
 *************************************************/

function weeklyOSValidateCastOuts_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(day);

  day.castOuts.forEach(function (outItem) {

    const person =
      outItem.person ||
      "Unknown cast member";

    if (!outItem.person) {
      weeklyOSAddValidationError_(result, {
        code: "CAST_OUT_MISSING_PERSON",
        date: day.date,
        message:
          label +
          " contains a cast out without a person."
      });
    }

    if (!outItem.role) {
      weeklyOSAddValidationWarning_(result, {
        code: "CAST_OUT_MISSING_ROLE",
        date: day.date,
        message:
          label +
          ": " +
          person +
          " is OUT, but the role is missing."
      });
    }

    if (
      !outItem.coverage &&
      !weeklyOSOutDoesNotRequireCoverage_(outItem)
    ) {
      weeklyOSAddValidationError_(result, {
        code: "CAST_OUT_MISSING_COVERAGE",
        date: day.date,
        message:
          label +
          ": coverage is missing for " +
          person +
          (
            outItem.role
              ? " (" + outItem.role + ")"
              : ""
          ) +
          "."
      });
    }

    if (!outItem.approvalStatus) {
      weeklyOSAddValidationWarning_(result, {
        code: "CAST_OUT_MISSING_APPROVAL",
        date: day.date,
        message:
          label +
          ": " +
          person +
          "'s out does not have an approval status."
      });
    }

    /*
     * Two-show validation.
     *
     * ALL means BOTH.
     * MAT and EVE are also explicit.
     * Only warn if the scope is actually unknown.
     */
    if (day.performances.length > 1) {

      const appliesTo =
        weeklyOSUpper_(
          outItem.appliesTo
        );

      const explicit =
        appliesTo === "ALL" ||
        appliesTo === "BOTH" ||
        appliesTo === "MAT" ||
        appliesTo === "EVE";

      if (!explicit) {
        weeklyOSAddValidationWarning_(result, {
          code: "CAST_OUT_TWO_SHOW_SCOPE",
          date: day.date,
          message:
            label +
            ": confirm whether " +
            person +
            "'s out applies to MAT, EVE, or both."
        });
      }
    }

    if (
      outItem.requiresReview &&
      !weeklyOSOutDoesNotRequireCoverage_(outItem)
    ) {
      weeklyOSAddValidationError_(result, {
        code: "CAST_OUT_NEEDS_REVIEW",
        date: day.date,
        message:
          label +
          ": " +
          person +
          "'s out still needs review."
      });
    }

  });
}


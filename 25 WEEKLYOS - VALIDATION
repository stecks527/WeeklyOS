/*************************************************
 * 25 WEEKLYOS - VALIDATION
 * Version: 0.2.0
 * Status: ACTIVE DEVELOPMENT
 *
 * Validates WeeklyOS drafts before generation.
 *
 * Validation levels:
 *
 * ERROR
 *   Blocks Weekly Schedule generation.
 *
 * WARNING
 *   Does not block generation, but should be
 *   reviewed by the Stage Manager.
 *
 * INFO
 *   Useful context only.
 *************************************************/


/*************************************************
 * VALIDATE FULL DRAFT
 *************************************************/

function weeklyOSValidateDraft(draft) {
  const result = {
    isValid: true,

    errors: [],

    warnings: [],

    info: [],

    summary: {
      errorCount: 0,

      warningCount: 0,

      infoCount: 0,

      daysReady: 0,

      daysNeedingReview: 0
    }
  };

  if (!draft) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "NO_DRAFT",

        message:
          "No WeeklyOS draft exists."
      }
    );

    return weeklyOSFinalizeValidationResult_(
      result
    );
  }

  weeklyOSValidateDraftIdentity_(
    draft,
    result
  );

  weeklyOSValidateDraftDates_(
    draft,
    result
  );

  weeklyOSValidateDraftStructure_(
    draft,
    result
  );

  (
    Array.isArray(draft.days)
      ? draft.days
      : []
  ).forEach(
    function (day) {
      weeklyOSValidateDay_(
        day,
        draft,
        result
      );
    }
  );

  weeklyOSValidateSourceStatus_(
    draft,
    result
  );

  weeklyOSValidateDuplicatePerformances_(
    draft,
    result
  );

  weeklyOSValidatePerformanceSequence_(
    draft,
    result
  );

  weeklyOSValidateGeneratedSheetStatus_(
    draft,
    result
  );

  return weeklyOSFinalizeValidationResult_(
    result
  );
}


/*************************************************
 * VALIDATE DRAFT IDENTITY
 *************************************************/

function weeklyOSValidateDraftIdentity_(
  draft,
  result
) {
  if (!draft.id) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "MISSING_DRAFT_ID",

        message:
          "The WeeklyOS draft is missing its draft ID."
      }
    );
  }

  if (!draft.status) {
    weeklyOSAddValidationWarning_(
      result,
      {
        code:
          "MISSING_DRAFT_STATUS",

        message:
          "The WeeklyOS draft does not have a status."
      }
    );
  }

  if (!draft.schemaVersion) {
    weeklyOSAddValidationWarning_(
      result,
      {
        code:
          "MISSING_SCHEMA_VERSION",

        message:
          "The WeeklyOS draft does not identify its WeekModel version."
      }
    );
  }
}


/*************************************************
 * VALIDATE WEEK DATES
 *************************************************/

function weeklyOSValidateDraftDates_(
  draft,
  result
) {
  const weekStart =
    weeklyOSAsDate_(
      draft.weekStart
    );

  const weekEnd =
    weeklyOSAsDate_(
      draft.weekEnd
    );

  if (!weekStart) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "INVALID_WEEK_START",

        message:
          "The WeeklyOS draft has an invalid Monday date."
      }
    );
  }

  if (!weekEnd) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "INVALID_WEEK_END",

        message:
          "The WeeklyOS draft has an invalid Sunday date."
      }
    );
  }

  if (
    weekStart &&
    weekStart.getDay() !== 1
  ) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "WEEK_DOES_NOT_START_MONDAY",

        message:
          "The WeeklyOS week must begin on a Monday."
      }
    );
  }

  if (
    weekEnd &&
    weekEnd.getDay() !== 0
  ) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "WEEK_DOES_NOT_END_SUNDAY",

        message:
          "The WeeklyOS week must end on a Sunday."
      }
    );
  }

  if (
    weekStart &&
    weekEnd
  ) {
    const expectedEnd =
      weeklyOSAddDays_(
        weekStart,
        6
      );

    if (
      !weeklyOSDatesEqual_(
        expectedEnd,
        weekEnd
      )
    ) {
      weeklyOSAddValidationError_(
        result,
        {
          code:
            "INVALID_WEEK_RANGE",

          message:
            "The WeeklyOS draft must cover exactly Monday through Sunday."
        }
      );
    }
  }
}


/*************************************************
 * VALIDATE DRAFT STRUCTURE
 *************************************************/

function weeklyOSValidateDraftStructure_(
  draft,
  result
) {
  if (
    !Array.isArray(
      draft.days
    )
  ) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "MISSING_DAYS",

        message:
          "The WeeklyOS draft does not contain a days array."
      }
    );

    return;
  }

  if (
    draft.days.length !== 7
  ) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "INVALID_DAY_COUNT",

        message:
          "The WeeklyOS draft must contain exactly seven days."
      }
    );
  }

  const seenDates = {};

  draft.days.forEach(
    function (day) {
      const dateKey =
        weeklyOSDateKey_(
          day.date
        );

      if (!dateKey) {
        return;
      }

      if (
        seenDates[dateKey]
      ) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "DUPLICATE_DAY",

            date:
              dateKey,

            message:
              "The WeeklyOS draft contains more than one entry for " +
              dateKey +
              "."
          }
        );
      }

      seenDates[dateKey] =
        true;
    }
  );
}


/*************************************************
 * VALIDATE ONE DAY
 *************************************************/

function weeklyOSValidateDay_(
  day,
  draft,
  result
) {
  if (!day) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "INVALID_DAY",

        message:
          "A day in the WeeklyOS draft is empty."
      }
    );

    return;
  }

  weeklyOSEnsureDayModel_(
    day
  );

  const dateKey =
    weeklyOSDateKey_(
      day.date
    );

  if (!dateKey) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "MISSING_DAY_DATE",

        message:
          "A day in the WeeklyOS draft is missing its date."
      }
    );

    return;
  }

  if (
    !weeklyOSDateIsWithinRange_(
      dateKey,
      draft.weekStart,
      draft.weekEnd
    )
  ) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "DAY_OUTSIDE_WEEK",

        date:
          dateKey,

        message:
          weeklyOSValidationDayLabel_(
            day
          ) +
          " falls outside the selected WeeklyOS week."
      }
    );
  }

  weeklyOSValidateDaySchedule_(
    day,
    result
  );

  weeklyOSValidatePerformances_(
    day,
    result
  );

  weeklyOSValidateRehearsals_(
    day,
    result
  );

  weeklyOSValidateMeetings_(
    day,
    result
  );

  weeklyOSValidateWorkCalls_(
    day,
    result
  );

  weeklyOSValidatePutIns_(
    day,
    result
  );

  weeklyOSValidateCompanyEvents_(
    day,
    result
  );

  weeklyOSValidateCastOuts_(
    day,
    result
  );

  weeklyOSValidateCrewOuts_(
    day,
    result
  );

  weeklyOSValidatePt_(
    day,
    result
  );

  weeklyOSValidateNotes_(
    day,
    result
  );

  if (
    day.status ===
    "READY"
  ) {
    result.summary
      .daysReady++;
  } else {
    result.summary
      .daysNeedingReview++;
  }
}


/*************************************************
 * VALIDATE DAY SCHEDULE
 *************************************************/

function weeklyOSValidateDaySchedule_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  if (
    day.dayOff &&
    day.performances.length
  ) {
    weeklyOSAddValidationError_(
      result,
      {
        code:
          "DAY_OFF_WITH_PERFORMANCE",

        date:
          day.date,

        message:
          label +
          " is marked as a day off but also contains a performance."
      }
    );
  }

  if (
    day.dayOff &&
    (
      day.rehearsals.length ||
      day.meetings.length ||
      day.workCalls.length ||
      day.putIns.length
    )
  ) {
    weeklyOSAddValidationWarning_(
      result,
      {
        code:
          "DAY_OFF_WITH_ACTIVITY",

        date:
          day.date,

        message:
          label +
          " is marked as a day off but also contains scheduled activity."
      }
    );
  }

  if (
    !day.dayOff &&
    !day.performances.length &&
    !day.rehearsals.length &&
    !day.meetings.length &&
    !day.workCalls.length &&
    !day.putIns.length &&
    !day.companyEvents.length &&
    !day.pt.length &&
    !day.notes.length
  ) {
    weeklyOSAddValidationInfo_(
      result,
      {
        code:
          "EMPTY_DAY",

        date:
          day.date,

        message:
          label +
          " contains no detected schedule or company activity."
      }
    );
  }

  if (!day.reviewed) {
    weeklyOSAddValidationWarning_(
      result,
      {
        code:
          "DAY_NOT_REVIEWED",

        date:
          day.date,

        message:
          label +
          " has not been marked reviewed."
      }
    );
  }
}


/*************************************************
 * VALIDATE PERFORMANCES
 *************************************************/

function weeklyOSValidatePerformances_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  day.performances.forEach(
    function (
      performance,
      index
    ) {
      const performanceLabel =
        performance.label ||
        (
          performance.performanceNumber
            ? "Performance #" +
              performance.performanceNumber
            : "Performance " +
              (index + 1)
        );

      if (
        !performance.label &&
        !performance.performanceNumber
      ) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "PERFORMANCE_MISSING_IDENTITY",

            date:
              day.date,

            message:
              label +
              " contains a performance without a label or performance number."
          }
        );
      }

      if (!performance.time) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "PERFORMANCE_MISSING_TIME",

            date:
              day.date,

            message:
              label +
              ": " +
              performanceLabel +
              " does not have a performance time."
          }
        );
      }

      if (!performance.showType) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "PERFORMANCE_MISSING_SHOW_TYPE",

            date:
              day.date,

            message:
              label +
              ": " +
              performanceLabel +
              " is not identified as MAT or EVE."
          }
        );
      }

      if (!performance.conductor) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "PERFORMANCE_MISSING_CONDUCTOR",

            date:
              day.date,

            message:
              label +
              ": " +
              performanceLabel +
              " does not have a conductor."
          }
        );
      }

      if (
        performance.showType &&
        [
          "MAT",
          "EVE"
        ].indexOf(
          weeklyOSUpper_(
            performance.showType
          )
        ) < 0
      ) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "UNRECOGNIZED_SHOW_TYPE",

            date:
              day.date,

            message:
              label +
              ": " +
              performanceLabel +
              ' has an unrecognized show type of "' +
              performance.showType +
              '".'
          }
        );
      }

      if (
        !performance.source
      ) {
        weeklyOSAddValidationInfo_(
          result,
          {
            code:
              "PERFORMANCE_MISSING_SOURCE",

            date:
              day.date,

            message:
              label +
              ": " +
              performanceLabel +
              " does not identify its source."
          }
        );
      }
    }
  );

  if (
    day.performances.length > 2
  ) {
    weeklyOSAddValidationWarning_(
      result,
      {
        code:
          "MORE_THAN_TWO_PERFORMANCES",

        date:
          day.date,

        message:
          label +
          " contains more than two performances."
      }
    );
  }

  if (
    day.performances.length === 2
  ) {
    const showTypes =
      day.performances.map(
        function (performance) {
          return weeklyOSUpper_(
            performance.showType
          );
        }
      );

    if (
      showTypes.indexOf(
        "MAT"
      ) < 0 ||
      showTypes.indexOf(
        "EVE"
      ) < 0
    ) {
      weeklyOSAddValidationWarning_(
        result,
        {
          code:
            "TWO_SHOW_TYPES_INCOMPLETE",

          date:
            day.date,

          message:
            label +
            " has two performances, but they are not clearly identified as one MAT and one EVE."
        }
      );
    }
  }
}


/*************************************************
 * VALIDATE REHEARSALS
 *************************************************/

function weeklyOSValidateRehearsals_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  day.rehearsals.forEach(
    function (
      rehearsal,
      index
    ) {
      const rehearsalLabel =
        rehearsal.title ||
        "Rehearsal " +
        (index + 1);

      if (rehearsal.canceled) {
        return;
      }

      if (!rehearsal.title) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "REHEARSAL_MISSING_TITLE",

            date:
              day.date,

            message:
              label +
              " contains a rehearsal without a title."
          }
        );
      }

      if (!rehearsal.startTime) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "REHEARSAL_MISSING_START_TIME",

            date:
              day.date,

            message:
              label +
              ": " +
              rehearsalLabel +
              " does not have a start time."
          }
        );
      }

      if (
        rehearsal.type ===
          "UNDERSTUDY" &&
        !rehearsal.location
      ) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "UNDERSTUDY_REHEARSAL_MISSING_LOCATION",

            date:
              day.date,

            message:
              label +
              ": " +
              rehearsalLabel +
              " does not have a location."
          }
        );
      }

      if (
        rehearsal.type ===
          "NEW_HIRE" &&
        !rehearsal.location
      ) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "NEW_HIRE_REHEARSAL_MISSING_LOCATION",

            date:
              day.date,

            message:
              label +
              ": " +
              rehearsalLabel +
              " needs a rehearsal location."
          }
        );
      }

      if (
        rehearsal.type ===
          "UNDERSTUDY" &&
        !rehearsal.called.length
      ) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "UNDERSTUDY_REHEARSAL_MISSING_CALLED",

            date:
              day.date,

            message:
              label +
              ": " +
              rehearsalLabel +
              " does not have a called list."
          }
        );
      }

      if (
        rehearsal.requiresReview
      ) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "REHEARSAL_NEEDS_REVIEW",

            date:
              day.date,

            message:
              label +
              ": " +
              rehearsalLabel +
              " still needs review."
          }
        );
      }

      if (
        rehearsal.startTime &&
        rehearsal.endTime &&
        !weeklyOSIsValidTimeOrder_(
          rehearsal.startTime,
          rehearsal.endTime
        )
      ) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "REHEARSAL_TIME_ORDER",

            date:
              day.date,

            message:
              label +
              ": " +
              rehearsalLabel +
              " may have an end time earlier than its start time."
          }
        );
      }
    }
  );
}


/*************************************************
 * VALIDATE MEETINGS
 *************************************************/

function weeklyOSValidateMeetings_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  day.meetings.forEach(
    function (
      meeting,
      index
    ) {
      const meetingLabel =
        meeting.title ||
        "Meeting " +
        (index + 1);

      if (!meeting.title) {
        weeklyOSAddValidationError_(
          result,
          {
            code:
              "MEETING_MISSING_TITLE",

            date:
              day.date,

            message:
              label +
              " contains a meeting without a title."
          }
        );
      }

      if (!meeting.startTime) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "MEETING_MISSING_START_TIME",

            date:
              day.date,

            message:
              label +
              ": " +
              meetingLabel +
              " does not have a start time."
          }
        );
      }

      if (
        meeting.replacesExistingCall &&
        !meeting.notes
      ) {
        weeklyOSAddValidationInfo_(
          result,
          {
            code:
              "MEETING_REPLACES_CALL_WITHOUT_NOTE",

            date:
              day.date,

            message:
              label +
              ": " +
              meetingLabel +
              " replaces an existing call but does not include an explanatory note."
          }
        );
      }
    }
  );
}


/*************************************************
 * VALIDATE WORK CALLS
 *************************************************/

function weeklyOSValidateWorkCalls_(

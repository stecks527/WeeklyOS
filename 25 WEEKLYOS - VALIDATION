/*************************************************
 * VALIDATE PT
 *************************************************/

function weeklyOSValidatePt_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  day.pt.forEach(
    function (
      ptItem,
      index
    ) {
      if (!ptItem.startTime) {
        weeklyOSAddValidationWarning_(
          result,
          {
            code:
              "PT_MISSING_START_TIME",

            date:
              day.date,

            message:
              label +
              ": PT item " +
              (index + 1) +
              " does not have a start time."
          }
        );
      }

      if (!ptItem.location) {
        weeklyOSAddValidationInfo_(
          result,
          {
            code:
              "PT_MISSING_LOCATION",

            date:
              day.date,

            message:
              label +
              ": PT does not identify a location."
          }
        );
      }
    }
  );
}


/*************************************************
 * VALIDATE NOTES
 *************************************************/

function weeklyOSValidateNotes_(
  day,
  result
) {
  const label =
    weeklyOSValidationDayLabel_(
      day
    );

  day.notes.forEach(
    function (
      note,
      index
    ) {
      const text =
        typeof note ===
          "string"
          ? weeklyOSNormalizeText_(
              note
            )
          : weeklyOSNormalizeText_(
              note.text
            );

      if (!text) {
        weeklyOSAddValidationInfo_(
          result,
          {
            code:
              "EMPTY_NOTE",

            date:
              day.date,

            message:
              label +
              " contains an empty note at position " +
              (index + 1) +
              "."
          }
        );
      }
    }
  );
}


/*************************************************
 * VALIDATE SOURCE STATUS
 *************************************************/

function weeklyOSValidateSourceStatus_(
  draft,
  result
) {
  const statuses =
    draft.sourceStatus || {};

  const requiredSources = [
    {
      key:
        "expandedCalendar",

      label:
        "Expanded Calendar",

      blocking:
        true
    },

    {
      key:
        "productionCalendar",

      label:
        "Production Calendar",

      blocking:
        false
    },

    {
      key:
        "pdVacationTracker",

      label:
        "PD/Vacation Tracker",

      blocking:
        false
    },

    {
      key:
        "crewOuts",

      label:
        "Crew Outs",

      blocking:
        false
    },

    {
      key:
        "contactSheet",

      label:
        "Contact Sheet",

      blocking:
        false
    }
  ];

  requiredSources.forEach(
    function (source) {
      const status =
        statuses[
          source.key
        ];

      if (
        !status ||
        !status.found
      ) {
        const item = {
          code:
            "SOURCE_NOT_FOUND",

          source:
            source.label,

          message:
            source.label +
            " was not found or could not be read."
        };

        if (
          source.blocking
        ) {
          weeklyOSAddValidationError_(
            result,
            item
          );
        } else {
          weeklyOSAddValidationWarning_(
            result,
            item
          );
        }
      }
    }
  );
}


/*************************************************
 * VALIDATE DUPLICATE PERFORMANCE NUMBERS
 *************************************************/

function weeklyOSValidateDuplicatePerformances_(
  draft,
  result
) {
  const seen = {};

  draft.days.forEach(
    function (day) {
      day.performances.forEach(
        function (performance) {
          const number =
            weeklyOSNormalizeText_(
              performance
                .performanceNumber
            );

          if (!number) {
            return;
          }

          if (seen[number]) {
            weeklyOSAddValidationError_(
              result,
              {
                code:
                  "DUPLICATE_PERFORMANCE_NUMBER",

                date:
                  day.date,

                message:
                  "Performance #" +
                  number +
                  " appears more than once in this WeeklyOS draft."
              }
            );

            return;
          }

          seen[number] =
            day.date;
        }
      );
    }
  );
}


/*************************************************
 * VALIDATE PERFORMANCE SEQUENCE
 *************************************************/

function weeklyOSValidatePerformanceSequence_(
  draft,
  result
) {
  const performances = [];

  draft.days.forEach(
    function (day) {
      day.performances.forEach(
        function (performance) {
          const number =
            Number(
              performance
                .performanceNumber
            );

          if (
            !isNaN(number)
          ) {
            performances.push({
              number:
                number,

              date:
                day.date
            });
          }
        }
      );
    }
  );

  performances.sort(
    function (first, second) {
      return (
        new Date(
          first.date
        ).getTime() -
        new Date(
          second.date
        ).getTime()
      );
    }
  );

  for (
    let index = 1;
    index <
      performances.length;
    index++
  ) {
    const previous =
      performances[
        index - 1
      ];

    const current =
      performances[index];

    if (
      current.number <=
      previous.number
    ) {
      weeklyOSAddValidationWarning_(
        result,
        {
          code:
            "PERFORMANCE_SEQUENCE",

          date:
            current.date,

          message:
            "Performance #" +
            current.number +
            " does not follow Performance #" +
            previous.number +
            " in ascending order."
        }
      );
    }
  }
}


/*************************************************
 * VALIDATE GENERATED SHEET STATUS
 *************************************************/

function weeklyOSValidateGeneratedSheetStatus_(
  draft,
  result
) {
  if (
    draft.status ===
      "GENERATED" &&
    (
      !draft.metadata ||
      !draft.metadata
        .generatedSheetName
    )
  ) {
    weeklyOSAddValidationWarning_(
      result,
      {
        code:
          "GENERATED_WITHOUT_SHEET",

        message:
          "The draft is marked GENERATED, but no generated sheet name is stored."
      }
    );
  }
}


/*************************************************
 * OUT COVERAGE EXCEPTION
 *
 * LOA and MLOA may still need downstream handling,
 * but WeeklyOS should not always require a coverage
 * assignment in the weekly schedule draft itself.
 *************************************************/

function weeklyOSOutDoesNotRequireCoverage_(
  outItem
) {
  const type =
    weeklyOSUpper_(
      outItem.type ||
      outItem.reason
    );

  return (
    type === "LOA" ||
    type === "MLOA"
  );
}


/*************************************************
 * ASSERT DRAFT IS READY
 *
 * Called by the generator.
 *************************************************/

function weeklyOSAssertDraftReady_(
  draft
) {
  const validation =
    weeklyOSValidateDraft(
      draft
    );

  if (
    validation.isValid
  ) {
    return validation;
  }

  const errorLines =
    validation.errors.map(
      function (item) {
        return (
          "• " +
          item.message
        );
      }
    );

  throw new Error(
    "WeeklyOS draft is not ready to generate:\n\n" +
    errorLines.join("\n")
  );
}


/*************************************************
 * ADD VALIDATION ITEMS
 *************************************************/

function weeklyOSAddValidationError_(
  result,
  item
) {
  result.errors.push(
    weeklyOSCreateValidationItem_(
      "ERROR",
      item
    )
  );
}


function weeklyOSAddValidationWarning_(
  result,
  item
) {
  result.warnings.push(
    weeklyOSCreateValidationItem_(
      "WARNING",
      item
    )
  );
}


function weeklyOSAddValidationInfo_(
  result,
  item
) {
  result.info.push(
    weeklyOSCreateValidationItem_(
      "INFO",
      item
    )
  );
}


/*************************************************
 * CREATE VALIDATION ITEM
 *************************************************/

function weeklyOSCreateValidationItem_(
  level,
  input
) {
  input = input || {};

  return {
    id:
      weeklyOSUuid_(),

    level:
      level,

    code:
      input.code ||
      "GENERAL",

    date:
      input.date ||
      "",

    source:
      input.source ||
      "",

    message:
      weeklyOSNormalizeText_(
        input.message
      )
  };
}


/*************************************************
 * FINALIZE VALIDATION RESULT
 *************************************************/

function weeklyOSFinalizeValidationResult_(
  result
) {
  result.errors =
    weeklyOSDeduplicateValidationItems_(
      result.errors
    );

  result.warnings =
    weeklyOSDeduplicateValidationItems_(
      result.warnings
    );

  result.info =
    weeklyOSDeduplicateValidationItems_(
      result.info
    );

  result.summary.errorCount =
    result.errors.length;

  result.summary.warningCount =
    result.warnings.length;

  result.summary.infoCount =
    result.info.length;

  result.isValid =
    result.errors.length === 0;

  return result;
}


/*************************************************
 * DEDUPLICATE VALIDATION ITEMS
 *************************************************/

function weeklyOSDeduplicateValidationItems_(
  items
) {
  const seen = {};

  return (
    Array.isArray(items)
      ? items
      : []
  ).filter(
    function (item) {
      const key = [
        item.level || "",
        item.code || "",
        item.date || "",
        item.message || ""
      ].join("|");

      if (
        seen[key]
      ) {
        return false;
      }

      seen[key] =
        true;

      return true;
    }
  );
}


/*************************************************
 * DAY LABEL FOR VALIDATION MESSAGES
 *************************************************/

function weeklyOSValidationDayLabel_(
  day
) {
  return (
    day.dateLabel ||
    weeklyOSFormatDate_(
      day.date,
      "EEEE, MMMM d"
    ) ||
    "Unknown day"
  );
}


/*************************************************
 * BASIC TIME ORDER CHECK
 *
 * This is intentionally forgiving because the
 * schedule may use formats such as:
 *
 * 12:00 PM
 * 12 PM
 * Noon
 * Midnight
 *************************************************/

function weeklyOSIsValidTimeOrder_(
  startTime,
  endTime
) {
  const startMinutes =
    weeklyOSTimeToMinutes_(
      startTime
    );

  const endMinutes =
    weeklyOSTimeToMinutes_(
      endTime
    );

  if (
    startMinutes === null ||
    endMinutes === null
  ) {
    return true;
  }

  return (
    endMinutes >=
    startMinutes
  );
}


/*************************************************
 * CONVERT TIME TEXT TO MINUTES
 *************************************************/

function weeklyOSTimeToMinutes_(
  value
) {
  const text =
    weeklyOSUpper_(
      value
    );

  if (!text) {
    return null;
  }

  if (
    text === "NOON"
  ) {
    return 12 * 60;
  }

  if (
    text === "MIDNIGHT"
  ) {
    return 0;
  }

  const match =
    text.match(
      /^(\d{1,2})(?::(\d{2}))?\s*(AM|PM)?/
    );

  if (!match) {
    return null;
  }

  let hour =
    Number(
      match[1]
    );

  const minutes =
    Number(
      match[2] || 0
    );

  const meridiem =
    match[3] || "";

  if (
    minutes < 0 ||
    minutes > 59
  ) {
    return null;
  }

  if (
    meridiem === "PM" &&
    hour !== 12
  ) {
    hour += 12;
  }

  if (
    meridiem === "AM" &&
    hour === 12
  ) {
    hour = 0;
  }

  if (
    hour < 0 ||
    hour > 23
  ) {
    return null;
  }

  return (
    hour * 60 +
    minutes
  );
}

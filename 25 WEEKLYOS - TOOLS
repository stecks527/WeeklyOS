function clean(text) {
  return String(text || "")
    .replace(/^NOTES:\s*/i, "")
    .replace(/^-+\s*/, "")
    .replace(/\s+/g, " ")
    .trim();
}


function cleanForRange(text) {
  return String(text || "")
    .replace(/\s+in the evenings\.?$/i, "")
    .trim();
}


function formatLine(text) {
  return clean(text);
}


